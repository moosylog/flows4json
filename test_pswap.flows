uid = "punct_swap"
type = "mutation"
language = "en-US"
title = "Programmer Punctuation Swap"
subtitle = "Invert Semicolon, Quotes & F4"
description = """
## ⚠️ Developer Preview: Requires the latest unreleased version of the Layout Editor.
---

Swaps the shifted and unshifted states of common punctuation keys using Mod-Morphs, and adds an optional Tap-Dance for F4 to close windows.

**Features:**
- Automatically improves how certain keys behave in your keyboard setup.
- Lets the semicolon and quote keys switch to their alternate symbols when needed (for example `:` instead of `;`, and `"` instead of `'`).
- Adds a double-tap shortcut on **F4** to quickly close the active window. (Alt F4)
- Fully optional—each feature can be turned on or off independently.
"""

# ==============================================================================
# JQ SCRIPT
# ==============================================================================
script = """
# ZMK Autonomous Injection Script - Punctuation Swap & F4 Close

# ==============================================================================
# 1. BEHAVIOR DEFINITIONS
# ==============================================================================

def get_mm_semi: {
  "name": "&mm_swap_semi",
  "description": "Mod-Morph: Colon / Semicolon",
  "cases": [
    {
      "binding": { "value": "&kp", "params": [{"value": "LS", "params": [{"value": "SEMI"}]}] },
      "mods": [],
      "keepMods": []
    },
    {
      "binding": { "value": "&kp", "params": [{"value": "SEMI"}] },
      "mods": ["MOD_LSFT", "MOD_RSFT"],
      "keepMods": []
    }
  ]
};

def get_mm_sqt: {
  "name": "&mm_swap_sqt",
  "description": "Mod-Morph: D-Quote / S-Quote",
  "cases": [
    {
      "binding": { "value": "&kp", "params": [{"value": "LS", "params": [{"value": "SQT"}]}] },
      "mods": [],
      "keepMods": []
    },
    {
      "binding": { "value": "&kp", "params": [{"value": "SQT"}] },
      "mods": ["MOD_LSFT", "MOD_RSFT"],
      "keepMods": []
    }
  ]
};

def get_td_f4_close: {
  "name": "&td_f4_close",
  "description": "Tap-Dance: F4 / Alt+F4",
  "tappingTermMs": 200,
  "bindings": [
    {
      "value": "&kp",
      "params": [{"value": "F4"}]
    },
    {
      "value": "&kp",
      "params": [{"value": "LA", "params": [{"value": "F4"}]}]
    }
  ]
};

# ==============================================================================
# 2. MAIN TRANSFORMATION ENGINE
# ==============================================================================

(.keymap // .) |= (
  
  # Step 1: Inject Mod-Morph behaviors into AST if enabled by UI parameters
  .modMorphs = (
    (.modMorphs // []) 
    + (if $swap_semi == "yes" then [get_mm_semi] else [] end)
    + (if $swap_sqt == "yes" then [get_mm_sqt] else [] end)
    | unique_by(.name)
  ) |

  # Step 2: Inject Tap-Dance behaviors into AST if enabled by UI parameters
  .tapDances = (
    (.tapDances // [])
    + (if $td_f4 == "yes" then [get_td_f4_close] else [] end)
    | unique_by(.name)
  ) |

  # Step 3: Auto-Assign on Base Layer (Layer 0)
  (if (.layers | length > 0) then
    
    # Build a target map based on UI selections
    (
      (if $swap_semi == "yes" then { "SEMI": {"value": "&mm_swap_semi"} } else {} end) +
      (if $swap_sqt == "yes"  then { "SQT":  {"value": "&mm_swap_sqt"} } else {} end) +
      (if $td_f4 == "yes"     then { "F4":   {"value": "&td_f4_close"}  } else {} end)
    ) as $map |
    
    # Iterate over the base layer keys
    .layers[0] |= map(
      if type == "object" and .value == "&kp" and .params and (.params | length > 0) and (.params[0].value | in($map)) then
        # Replace the key with the mapped Behavior (0 parameters) and preserve decorations
        $map[.params[0].value] + (if .decoration then {decoration: .decoration} else {} end)
      else
        .
      end
    )
    
  else . end)
)
"""

# ==============================================================================
# UI PARAMETERS 
# ==============================================================================

[[param]]
id = "swap_semi"
label = "Swap Semicolon / Colon"
type = "select"
options = ["yes", "no"]
labels = ["Yes (Tap: Colon, Shift: Semicolon)", "No (Keep Default)"]
default = "yes"

[[param]]
id = "swap_sqt"
label = "Swap Single / Double Quotes"
type = "select"
options = ["yes", "no"]
labels = ["Yes (Tap: Double, Shift: Single)", "No (Keep Default)"]
default = "yes"

[[param]]
id = "td_f4"
label = "F4 Double Tap to Close"
type = "select"
options = ["yes", "no"]
labels = ["Yes (Tap: F4, Double Tap: Alt+F4)", "No (Keep Default)"]
default = "yes"

# ==============================================================================
# METADATA & CONFIG
# ==============================================================================

[manifest]
author = "moosyresearch"
keyboards = ["go60", "glove80"]
icon = "🔀"      
theme = "blue" 

[config]
category = "Test/Dev"
