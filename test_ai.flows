uid = "AI_control"
type = "mutation"
language = "en-US"
title = "AI control layer"
subtitle = "Claude Layer Inject"
description = """
## ?? Developer Preview: Requires the upcoming Layout Editor release.
Injects the Dongdong AI Control layout into your Glove80.

https://discord.com/channels/877392805654306816/1193051200938049546/1527525298856529931

## NOT TESTED

**What this does:**
1. Adds a dedicated `AI_Control` layer populated with specialized AI macros.
2. Creates or updates the `Lower` layer with matching navigation/media bindings.
3. Automatically generates all 15+ AI formatting and command macros.
4. Generates Sticky Key behaviors required for the layout.

**Safety Features:**
* **Glove80 Only:** The script verifies your hardware before running.
* **Layer Check:** If `AI_Control` already exists, it will stop immediately to prevent corrupting your layout.
* **Non-Destructive Behaviors:** If any macro or behavior (like `&sticky_key_oneshot`) already exists, it safely skips them and keeps your original settings intact.
"""
# ==============================================================================
# METADATA & CONFIG
# ==============================================================================
[manifest]
author = "Dongdong"
keyboards = ["glove80"]
icon = "🤖"      
theme = "purple" 

[config]
category = "Productivity"

# ==============================================================================
# JQ SCRIPT 
# ==============================================================================
script = """
(if type == "object" and .keymap? then .keymap else . end) |= (
  
  # ----------------------------------------------------------------------------
  # 1. PRE-FLIGHT SAFETY CHECKS
  # ----------------------------------------------------------------------------
  
  # Check 1: Enforce Glove80 Only
  (if (.keyboard | type == "string" and ascii_downcase == "glove80") | not then
    error("FATAL: This flow is exclusively for the Glove80 keyboard.")
  else . end) |

  # Check 2: Abort if AI_Control layer already exists
  (if ((.layer_names // []) | index("AI_Control")) != null then
    error("FATAL: Layer 'AI_Control' already exists. Aborting to prevent duplicates.")
  else . end) |

  # ----------------------------------------------------------------------------
  # 2. BEHAVIOR INJECTIONS (Idempotent - Skips if already exists)
  # ----------------------------------------------------------------------------
  
  # Inject Sticky Keys safely (This fixes the missing &sticky_key_quickrel error)
  .stickyKeys = ((.stickyKeys // []) + [
    { "name": "&sticky_key_quickrel", "description": "Quick Release Sticky Key", "releaseAfterMs": 500, "quickRelease": true, "lazy": false, "ignoreModifiers": true, "bindings": ["&kp"] }
  ] | unique_by(.name)) |

  # Inject HoldTaps safely
  .holdTaps = ((.holdTaps // []) + [
    { "name": "&sticky_key_modtap", "description": "", "flavor": "tap-preferred", "tappingTermMs": 250, "bindings": ["&kp", "&sticky_key_oneshot"] }
  ] | unique_by(.name)) |

  # Inject Macros safely
  .macros = ((.macros // []) + [
    {"name":"&ai_usage","description":"Zero-config AI: Usage","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"U"}]},{"value":"&kp","params":[{"value":"S"}]},{"value":"&kp","params":[{"value":"A"}]},{"value":"&kp","params":[{"value":"G"}]},{"value":"&kp","params":[{"value":"E"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&ai_composer","description":"","tapMs":30,"waitMs":15,"bindings":[{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"ESC"}]},{"value":"&kp","params":[{"value":"I"}]}]},
    {"name":"&ai_claude_background","description":"Zero-config AI: Claude Background","tapMs":15,"waitMs":15,"bindings":[{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"LC","params":[{"value":"X"}]}]},{"value":"&kp","params":[{"value":"LC","params":[{"value":"B"}]}]}]},
    {"name":"&ai_claude_btw","description":"Zero-config AI: Claude BTW","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"B"}]},{"value":"&kp","params":[{"value":"T"}]},{"value":"&kp","params":[{"value":"W"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&ai_claude_agents","description":"Zero-config AI: Claude Agents","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"A"}]},{"value":"&kp","params":[{"value":"G"}]},{"value":"&kp","params":[{"value":"E"}]},{"value":"&kp","params":[{"value":"N"}]},{"value":"&kp","params":[{"value":"T"}]},{"value":"&kp","params":[{"value":"S"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&ai_codex_side","description":"Zero-config AI: Codex Side","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"S"}]},{"value":"&kp","params":[{"value":"I"}]},{"value":"&kp","params":[{"value":"D"}]},{"value":"&kp","params":[{"value":"E"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&ai_codex_raw","description":"Zero-config AI: Codex Raw","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"R"}]},{"value":"&kp","params":[{"value":"A"}]},{"value":"&kp","params":[{"value":"W"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&ai_codex_fast","description":"Zero-config AI: Codex Fast","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"F"}]},{"value":"&kp","params":[{"value":"A"}]},{"value":"&kp","params":[{"value":"S"}]},{"value":"&kp","params":[{"value":"T"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&ai_claude_new","description":"Zero-config AI: New Claude","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"C"}]},{"value":"&kp","params":[{"value":"L"}]},{"value":"&kp","params":[{"value":"E"}]},{"value":"&kp","params":[{"value":"A"}]},{"value":"&kp","params":[{"value":"R"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&ai_permissions","description":"Zero-config AI: Permissions","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"P"}]},{"value":"&kp","params":[{"value":"E"}]},{"value":"&kp","params":[{"value":"R"}]},{"value":"&kp","params":[{"value":"M"}]},{"value":"&kp","params":[{"value":"I"}]},{"value":"&kp","params":[{"value":"S"}]},{"value":"&kp","params":[{"value":"S"}]},{"value":"&kp","params":[{"value":"I"}]},{"value":"&kp","params":[{"value":"O"}]},{"value":"&kp","params":[{"value":"N"}]},{"value":"&kp","params":[{"value":"S"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&ai_claude_effort_down","description":"Zero-config AI: Claude Effort Down","tapMs":15,"waitMs":15,"bindings":[{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"LA","params":[{"value":"P"}]}]},{"value":"&kp","params":[{"value":"LEFT"}]}]},
    {"name":"&ai_claude_effort_up","description":"Zero-config AI: Claude Effort Up","tapMs":15,"waitMs":15,"bindings":[{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"LA","params":[{"value":"P"}]}]},{"value":"&kp","params":[{"value":"RIGHT"}]}]},
    {"name":"&ai_model","description":"Zero-config AI: Model","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"M"}]},{"value":"&kp","params":[{"value":"O"}]},{"value":"&kp","params":[{"value":"D"}]},{"value":"&kp","params":[{"value":"E"}]},{"value":"&kp","params":[{"value":"L"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&ai_status","description":"Zero-config AI: Status","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"S"}]},{"value":"&kp","params":[{"value":"T"}]},{"value":"&kp","params":[{"value":"A"}]},{"value":"&kp","params":[{"value":"T"}]},{"value":"&kp","params":[{"value":"U"}]},{"value":"&kp","params":[{"value":"S"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&ai_claude_copy","description":"Zero-config AI: Claude Copy","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"C"}]},{"value":"&kp","params":[{"value":"O"}]},{"value":"&kp","params":[{"value":"P"}]},{"value":"&kp","params":[{"value":"Y"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&ai_resume","description":"Zero-config AI: Resume","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"R"}]},{"value":"&kp","params":[{"value":"E"}]},{"value":"&kp","params":[{"value":"S"}]},{"value":"&kp","params":[{"value":"U"}]},{"value":"&kp","params":[{"value":"M"}]},{"value":"&kp","params":[{"value":"E"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&ai_compact","description":"Zero-config AI: Compact","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"C"}]},{"value":"&kp","params":[{"value":"O"}]},{"value":"&kp","params":[{"value":"M"}]},{"value":"&kp","params":[{"value":"P"}]},{"value":"&kp","params":[{"value":"A"}]},{"value":"&kp","params":[{"value":"C"}]},{"value":"&kp","params":[{"value":"T"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&ai_diff","description":"Zero-config AI: Diff","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"D"}]},{"value":"&kp","params":[{"value":"I"}]},{"value":"&kp","params":[{"value":"F"}]},{"value":"&kp","params":[{"value":"F"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&ai_review","description":"Zero-config AI: Review","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"R"}]},{"value":"&kp","params":[{"value":"E"}]},{"value":"&kp","params":[{"value":"V"}]},{"value":"&kp","params":[{"value":"I"}]},{"value":"&kp","params":[{"value":"E"}]},{"value":"&kp","params":[{"value":"W"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&ai_plan","description":"Zero-config AI: Plan","tapMs":15,"waitMs":15,"bindings":[{"value":"&ai_composer"},{"value":"&macro_tap"},{"value":"&kp","params":[{"value":"FSLH"}]},{"value":"&kp","params":[{"value":"P"}]},{"value":"&kp","params":[{"value":"L"}]},{"value":"&kp","params":[{"value":"A"}]},{"value":"&kp","params":[{"value":"N"}]},{"value":"&kp","params":[{"value":"ENTER"}]}]},
    {"name":"&sticky_key_oneshot","description":"","tapMs":0,"waitMs":0,"bindings":[{"value":"&macro_tap"},{"value":"&macro_param_1to1"},{"value":"&sticky_key_quickrel","params":[{"value":"MACRO_PLACEHOLDER"}]}]}
  ] | unique_by(.name)) |

  # ----------------------------------------------------------------------------
  # 3. LAYER INJECTIONS
  # ----------------------------------------------------------------------------
  
  # A. 'Lower' Layer Logic: Update if exists, otherwise append
  (
    [{"value":"&kp","params":[{"value":"C_BRI_DN"}]},{"value":"&kp","params":[{"value":"C_BRI_UP"}]},{"value":"&kp","params":[{"value":"C_PREV"}]},{"value":"&kp","params":[{"value":"C_NEXT"}]},{"value":"&kp","params":[{"value":"C_PP"}]},{"value":"&kp","params":[{"value":"C_MUTE"}]},{"value":"&kp","params":[{"value":"C_VOL_DN"}]},{"value":"&kp","params":[{"value":"C_VOL_UP"}]},{"value":"&none"},{"value":"&kp","params":[{"value":"PAUSE_BREAK"}]},{"value":"&trans"},{"value":"&none"},{"value":"&none"},{"value":"&none"},{"value":"&none"},{"value":"&kp","params":[{"value":"HOME"}]},{"value":"&kp","params":[{"value":"LS","params":[{"value":"N9"}]}]},{"value":"&kp","params":[{"value":"KP_NUM"}]},{"value":"&kp","params":[{"value":"KP_EQUAL"}]},{"value":"&kp","params":[{"value":"KP_SLASH"}]},{"value":"&kp","params":[{"value":"KP_MULTIPLY"}]},{"value":"&kp","params":[{"value":"PRINTSCREEN"}]},{"value":"&trans"},{"value":"&none"},{"value":"&none"},{"value":"&kp","params":[{"value":"UP_ARROW"}]},{"value":"&none"},{"value":"&kp","params":[{"value":"END"}]},{"value":"&kp","params":[{"value":"LS","params":[{"value":"N0"}]}]},{"value":"&kp","params":[{"value":"KP_N7"}]},{"value":"&kp","params":[{"value":"KP_N8"}]},{"value":"&kp","params":[{"value":"KP_N9"}]},{"value":"&kp","params":[{"value":"KP_MINUS"}]},{"value":"&kp","params":[{"value":"SCROLLLOCK"}]},{"value":"&trans"},{"value":"&none"},{"value":"&kp","params":[{"value":"LEFT_ARROW"}]},{"value":"&kp","params":[{"value":"DOWN_ARROW"}]},{"value":"&kp","params":[{"value":"RIGHT_ARROW"}]},{"value":"&kp","params":[{"value":"PG_UP"}]},{"value":"&kp","params":[{"value":"LS","params":[{"value":"N5"}]}]},{"value":"&kp","params":[{"value":"KP_N4"}]},{"value":"&kp","params":[{"value":"KP_N5"}]},{"value":"&kp","params":[{"value":"KP_N6"}]},{"value":"&kp","params":[{"value":"KP_PLUS"}]},{"value":"&none"},{"value":"&trans"},{"value":"&kp","params":[{"value":"K_APP"}]},{"value":"&none"},{"value":"&kp","params":[{"value":"F11"}]},{"value":"&kp","params":[{"value":"F12"}]},{"value":"&kp","params":[{"value":"PG_DN"}]},{"value":"&trans"},{"value":"&trans"},{"value":"&to","params":[{"value":0}]},{"value":"&trans"},{"value":"&trans"},{"value":"&trans"},{"value":"&kp","params":[{"value":"COMMA"}]},{"value":"&kp","params":[{"value":"KP_N1"}]},{"value":"&kp","params":[{"value":"KP_N2"}]},{"value":"&kp","params":[{"value":"KP_N3"}]},{"value":"&kp","params":[{"value":"KP_ENTER"}]},{"value":"&trans"},{"value":"&magic"},{"value":"&kp","params":[{"value":"CAPS"}]},{"value":"&kp","params":[{"value":"INS"}]},{"value":"&kp","params":[{"value":"F11"}]},{"value":"&kp","params":[{"value":"F12"}]},{"value":"&trans"},{"value":"&trans"},{"value":"&trans"},{"value":"&trans"},{"value":"&trans"},{"value":"&trans"},{"value":"&kp","params":[{"value":"KP_N0"}]},{"value":"&kp","params":[{"value":"KP_N0"}]},{"value":"&kp","params":[{"value":"KP_DOT"}]},{"value":"&kp","params":[{"value":"KP_ENTER"}]},{"value":"&trans"}]
  ) as $lower_keys |
  (.layer_names | index("Lower")) as $lower_idx |
  (if $lower_idx != null then
    .layers[$lower_idx] = $lower_keys
  else
    .layer_names += ["Lower"] | .layers += [$lower_keys]
  end) |

  # B. 'AI_Control' Layer Logic: Append layer and keys
  (
    [{"value":"&none"},{"value":"&none"},{"value":"&none"},{"value":"&none"},{"value":"&none"},{"value":"&none"},{"value":"&none"},{"value":"&none"},{"value":"&none"},{"value":"&none"},{"value":"&ai_usage","params":[],"decoration":{"label":"Usage /usage","background":"#bbdefb"}},{"value":"&ai_claude_background","decoration":{"label":"Background Ctrl+X, Ctrl+B","background":"#ede7f6"},"params":[]},{"value":"&kp","params":[{"value":"LC","params":[{"value":"S"}]}],"decoration":{"label":"Stash Ctrl+S","background":"#bbdefb"}},{"value":"&kp","params":[{"value":"LA","params":[{"value":"T"}]}],"decoration":{"label":"Thinking Alt+T","background":"#ede7f6"}},{"value":"&ai_claude_btw","params":[],"decoration":{"label":"BTW /btw","background":"#bbdefb"}},{"value":"&ai_claude_agents","decoration":{"label":"Agents /agents","background":"#bbdefb"},"params":[]},{"value":"&ai_claude_agents","decoration":{"label":"Agents /agents","background":"#bbdefb"},"params":[]},{"value":"&ai_codex_side","params":[],"decoration":{"label":"Side /side","background":"#bbdefb"}},{"value":"&ai_codex_raw","params":[],"decoration":{"label":"Raw /raw","background":"#bbdefb"}},{"value":"&kp","params":[{"value":"LA","params":[{"value":"UP"}]}],"decoration":{"background":"#bbdefb"}},{"value":"&ai_codex_fast","params":[],"decoration":{"label":"Fast /fast","background":"#bbdefb"}},{"value":"&ai_usage","params":[],"decoration":{"label":"Usage /usage","background":"#bbdefb"}},{"value":"&ai_claude_new","params":[],"decoration":{"label":"New /clear","background":"#bbdefb"}},{"value":"&ai_permissions","params":[],"decoration":{"label":"permission /permission","background":"#ede7f6"}},{"value":"&ai_claude_effort_down","decoration":{"label":"Effort Alt-P Left","background":"#ede7f6"},"params":[]},{"value":"&ai_claude_effort_up","decoration":{"label":"Effort Alt-P right","background":"#ede7f6"},"params":[]},{"value":"&ai_model","params":[],"decoration":{"label":"Model /model","background":"#ede7f6"}},{"value":"&kp","params":[{"value":"LC","params":[{"value":"O"}]}],"decoration":{"label":"Details Ctrl+O","background":"#bbdefb"}},{"value":"&kp","params":[{"value":"LC","params":[{"value":"O"}]}],"decoration":{"label":"Details Ctrl+O","background":"#bbdefb"}},{"value":"&ai_model","params":[],"decoration":{"label":"Model /model","background":"#ede7f6"}},{"value":"&ai_claude_effort_up","decoration":{"label":"Effort Alt-P right","background":"#ede7f6"},"params":[]},{"value":"&ai_claude_effort_down","decoration":{"label":"Effort Alt-P Left","background":"#ede7f6"},"params":[]},{"value":"&ai_permissions","params":[],"decoration":{"label":"permission /permission","background":"#ede7f6"}},{"value":"&ai_claude_new","params":[],"decoration":{"label":"New /clear","background":"#bbdefb"}},{"value":"&ai_status","params":[],"decoration":{"label":"Status /status","background":"#bbdefb"}},{"value":"&kp","params":[{"value":"N"}],"decoration":{"label":"Decline N","background":"#ffccbc"}},{"value":"&kp","params":[{"value":"UP"}],"decoration":{"background":"#e8f5e9"}},{"value":"&kp","params":[{"value":"DOWN"}],"decoration":{"background":"#e8f5e9"}},{"value":"&kp","params":[{"value":"Y"}],"decoration":{"label":"Accept Y","background":"#e8f5e9"}},{"value":"&ai_claude_copy","params":[],"decoration":{"label":"Copy /copy","background":"#bbdefb"}},{"value":"&ai_claude_copy","params":[],"decoration":{"label":"Copy /copy","background":"#bbdefb"}},{"value":"&kp","params":[{"value":"Y"}],"decoration":{"label":"Accept Y","background":"#e8f5e9"}},{"value":"&kp","params":[{"value":"DOWN"}],"decoration":{"background":"#e8f5e9"}},{"value":"&kp","params":[{"value":"UP"}],"decoration":{"background":"#e8f5e9"}},{"value":"&kp","params":[{"value":"N"}],"decoration":{"label":"Decline N","background":"#ffccbc"}},{"value":"&ai_status","params":[],"decoration":{"label":"Status /status","background":"#bbdefb"}},{"value":"&ai_resume","params":[],"decoration":{"label":"Resume /resume","background":"#bbdefb"}},{"value":"&ai_compact","params":[],"decoration":{"label":"Compact /compact","background":"#ffecb3"}},{"value":"&ai_diff","params":[],"decoration":{"label":"Diff /diff","background":"#ffecb3"}},{"value":"&ai_review","params":[],"decoration":{"label":"Review /review","background":"#ffecb3"}},{"value":"&ai_plan","params":[],"decoration":{"label":"Plan /plan","background":"#ffecb3"}},{"value":"&kp","params":[{"value":"LC","params":[{"value":"G"}]}],"decoration":{"label":"Editor Ctrl + G","background":"#bbdefb"}},{"value":"&kp","params":[{"value":"RET"}],"decoration":{"label":"Submit Enter","background":"#e8f5e9"}},{"value":"&kp","params":[{"value":"RET"}],"decoration":{"label":"Submit Enter","background":"#e8f5e9"}},{"value":"&ai_claude_background","decoration":{"background":"#ede7f6"},"params":[]},{"value":"&kp","params":[{"value":"TAB"}],"decoration":{"background":"#e4e2f0"}},{"value":"&kp","params":[{"value":"J"}],"decoration":{"label":"Newline Ctrl+J","background":"#ede7f6"}},{"value":"&kp","params":[{"value":"RET"}],"decoration":{"label":"Submit Enter","background":"#e8f5e9"}},{"value":"&kp","params":[{"value":"LC","params":[{"value":"G"}]}],"decoration":{"label":"Editor Ctrl + G","background":"#bbdefb"}},{"value":"&ai_plan","params":[],"decoration":{"label":"Plan /plan","background":"#ffecb3"}},{"value":"&ai_review","params":[],"decoration":{"label":"Review /review","background":"#ffecb3"}},{"value":"&ai_diff","params":[],"decoration":{"label":"Diff /diff","background":"#ffecb3"}},{"value":"&ai_compact","params":[],"decoration":{"label":"Compact /compact","background":"#ffecb3"}},{"value":"&ai_resume","params":[],"decoration":{"label":"Resume /resume","background":"#bbdefb"}},{"value":"&none"},{"value":"&none"},{"value":"&none"},{"value":"&none"},{"value":"&sticky_key_modtap","params":[{"value":"LSHFT"},{"value":"LSHFT"}],"decoration":{"label":"lShift","icon":"fa-angle-double-up","background":"#ffecb3"}},{"value":"&kp","params":[{"value":"Y"}],"decoration":{"label":"Accept Y","background":"#e8f5e9"}},{"value":"&kp","params":[{"value":"N"}],"decoration":{"label":"Decline N","background":"#ffccbc"}},{"value":"&kp","params":[{"value":"C"}],"decoration":{"label":"Stop","background":"#ffcdd2"}},{"value":"&kp","params":[{"value":"C"}],"decoration":{"label":"Stop","background":"#ffcdd2"}},{"value":"&kp","params":[{"value":"N"}],"decoration":{"label":"Decline N","background":"#ffccbc"}},{"value":"&kp","params":[{"value":"Y"}],"decoration":{"label":"Accept Y","background":"#e8f5e9"}},{"value":"&sticky_key_modtap","params":[{"value":"RSHFT"},{"value":"RSHFT"}],"decoration":{"label":"rShift","icon":"fa-angle-double-up","background":"#ffecb3"}},{"value":"&none"},{"value":"&none"},{"value":"&none"},{"value":"&none"}]
  ) as $ai_keys |
  .layer_names += ["AI_Control"] | .layers += [$ai_keys]
)
"""
