# ==============================================================================
# UI PARAMETERS
# ==============================================================================

[[param]]
id = "mod_preset"
label = "Recommended order"
type = "select"
options = ["GACS", "CAGS"]
labels = ["Windows / Linux", "macOS"]
default = "GACS"

# ==============================================================================
# METADATA & CONFIG
# ==============================================================================

[manifest]
author = "moosyresearch"
keyboards = ["go60"]
icon = "📦"
# Optional: red, green, blue, purple, yellow, orange
theme = "red"
[config]
category = "Test/Dev"
