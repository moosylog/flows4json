uid = "hrm_bil60"
type = "mutation"
language = "us"
title = "Sunaku's Bilateral HRMxx!"
subtitle = "Adds Home-Row Modifiers"
description = """
Advanced home-row mods with bilateral combination enforcement improve typing flow by placing modifiers directly under your fingertips.

[Learn more](https://sites.google.com/view/keyboards/layout/homerow-mods-explained)


**This injects**

- 16 macros 
- 32 hold-taps
- 1 new QWERTY HRM layer called 'HRM_Bil'
- 8 finger layers


**Notes**

⚠️ This module adds the layers and behaviors to your layout, but does not automatically organize or validate them in the Layout Editor. Manual layer setup is required.

⚠️ You can make 'HRM_Bil' your base layer and use QWERTY Swap to convert everything to another alpha layer, like Colemak-DH or other.
"""

# ==============================================================================
# JQ SCRIPT (Must remain at the top before any headers!)
# ==============================================================================
script = """
{
  "GACS": { "L1": "LGUI",  "R1": "RGUI",  "L2": "LCTRL", "R2": "RCTRL", "C1": "#d9f9c9", "C2":"#fbe6fe" },
  "CAGS": { "L1": "LCTRL", "R1": "RCTRL", "L2": "LGUI",  "R2": "RGUI",  "C1": "#fbe6fe", "C2":"#d9f9c9" }
}[$mod_preset] as $mod |

# ==============================================================================
# Go60 key layout (60 keys, sequential index):
#  Row 0  ( 0-11): F1-F12
#  Row 1  (12-23): =  1  2  3  4  5  | 6  7  8  9  0  -
#  Row 2  (24-35): TAB Q  W  E  R  T  | Y  U  I  O  P  \
#  Row 3  (36-47): ESC A  S  D  F  G  | H  J  K  L  ;  '   <- home row
#  Row 4L (48-50): `  Z  X
#  Row 4R (51-53): N  M  ,
#  Thumb L (54-56): LSHFT  MOD_L2  LCTRL
#  Thumb R (57-59): MOD_R2 RSHFT   SPACE
# ==============================================================================

# 1. Guarantee all required layers exist before resolving indices
(
  ["HRM_Bil","LeftPinky","LeftRingy","LeftMiddy","LeftIndex",
   "RightIndex","RightMiddy","RightRingy","RightPinky"] as $req |
  .layer_names |= (. // []) |
  .layers      |= (. // []) |
  reduce $req[] as $ln (
    .;
    if (.layer_names | index($ln)) == null then
      .layer_names += [$ln] | .layers += [[]]
    else . end
  )
) |

# 2. Resolve layer indices dynamically by name
(.layer_names | index("HRM_Bil"))    as $idx_hrm |
(.layer_names | index("LeftPinky"))  as $idx_lp  |
(.layer_names | index("LeftRingy"))  as $idx_lr  |
(.layer_names | index("LeftMiddy"))  as $idx_lm  |
(.layer_names | index("LeftIndex"))  as $idx_li  |
(.layer_names | index("RightIndex")) as $idx_ri  |
(.layer_names | index("RightMiddy")) as $idx_rm  |
(.layer_names | index("RightRingy")) as $idx_rr  |
(.layer_names | index("RightPinky")) as $idx_rp  |

# 3. Inject HoldTaps (32 bilateral hold-taps, Go60 holdTriggerKeyPositions)
