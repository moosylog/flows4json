uid = "top_15_zmk_behaviors"
type = "mutation"
language = "en-US"
title = "Top 15 Advanced Behaviors 🛠️"
subtitle = "Community Vetted Tap-Dances & Mod-Morphs"
description = """
Injects the **Top 15 Community-Vetted Use Cases** directly into your layout dictionary.

These combinations condense punctuation, macros, and layer toggles into highly optimized keys without disrupting your typing rhythm.

**Includes:**
* **9 Hold-Taps** (e.g., God-Tier Thumb Backspace, Media Maestro)
* **10 Mod-Morphs** (e.g., Smart Escape Corner, Punctuation Powerhouse)
* **12 Tap-Dances** (e.g., Peek-or-Lock Layer Space, Nested Brackets)
* **4 Macros** (e.g., End-of-Line, Arrow Operator)


### 1. Thumb Keys (Requires 1 Parameter for the "Hold" action)
*Bind these to your primary thumb arcs:*

| Behavior Action | Behavior Code & Parameter |
| :--- | :--- |
| **Hold:** Nav Layer <br> **Tap:** Backspace <br> **Shift+Tap:** Delete | `&ht_thumb_bspc` <br> *(Set param to a Layer Number, e.g., `1`)* |
| **Hold:** Num Layer <br> **Tap:** Space <br> **Double-Tap:** Locks Num Layer | `&ht_spc_peek_lock` <br> *(Set param to a Layer Number, e.g., `2`)* |
| **Hold:** Right Shift <br> **Tap:** Enter <br> **Double-Tap:** End of Line + `;` + Enter | `&ht_shift_enter` <br> *(Set param to `RSHFT`)* |
| **Hold:** Left Shift <br> **Tap:** `(` <br> **Double-Tap:** `)` | `&ht_space_cadet` <br> *(Set param to `LSHFT`)* |

---

### 2. Punctuation & Alphas (0 Parameters required)
*Drop these directly onto your base QWERTY layer in place of the standard symbol keys:*

| Behavior Action | Behavior Code & Parameter |
| :--- | :--- |
| **Tap:** `.` <br> **Shift+Tap:** `:` <br> **Double-Tap:** `...` | `&td_punct_power` <br> *(Replace your `.` key)* |
| **Tap:** `(` <br> **Shift+Tap:** `<` <br> **Double-Tap:** `[` <br> **Shift+Double:** `{` | `&td_nested_brackets` <br> *(Replace your `[` key)* |
| **Tap:** `/` <br> **Shift+Tap:** `?` <br> **Double-Tap:** `!` | `&td_quest_excl` <br> *(Replace your `/` key)* |
| **Tap:** `-` <br> **Shift+Tap:** `_` <br> **Double-Tap:** `->` | `&td_dash_arrow` <br> *(Replace your `-` key)* |
| **Tap:** `=` <br> **Shift+Tap:** `+` <br> **Double-Tap:** `=>` | `&td_math_logic` <br> *(Replace your `=` key)* |

---

### 3. Modifiers & System (Requires 1 Parameter for the "Hold" action)
*Bind these to your outer columns or function rows:*

| Behavior Action | Behavior Code & Parameter |
| :--- | :--- |
| **Hold:** Ctrl <br> **Tap:** ESC <br> **Shift+Tap:** `~` | `&ht_ctrl_esc` <br> *(Set param to `LCTRL`)* |
| **Hold:** Alt <br> **Tap:** Tab <br> **Shift+Tap:** Shift+Tab | `&ht_alt_tab` <br> *(Set param to `LALT` or `LGUI`)* |
| **Hold:** Shift <br> **Tap:** Shift <br> **Double-Tap:** Caps Word | `&ht_shift_caps` <br> *(Set param to `LSHFT`)* |
| **Hold:** Vol Up <br> **Tap:** Play/Pause <br> **Double:** Next <br> **Triple:** Prev | `&ht_vol_media` <br> *(Set param to `C_VOL_UP`)* |
*Note: Uses Safe-Merge architecture. It will only add new behaviors and will never delete your existing setup.*
"""

# ==============================================================================
# JQ SCRIPT
# ==============================================================================
script = """
# ZMK Autonomous Injection Script - "Top 15 Advanced Behaviors" (V2 - Repaired)

# --- 1. MACROS ---
([
  { "name": "&mac_eol_semi", "params": [], "description": "4. End of Line Macro: End + ; + Enter", "waitMs": 0, "tapMs": 0, "bindings": [ { "value": "&macro_tap", "params": [] }, { "value": "&kp", "params": [{"value": "END"}] }, { "value": "&kp", "params": [{"value": "SEMI"}] }, { "value": "&kp", "params": [{"value": "RET"}] } ] },
  { "name": "&mac_ellipsis", "params": [], "description": "9. Ellipsis Macro: ...", "waitMs": 0, "tapMs": 0, "bindings": [ { "value": "&macro_tap", "params": [] }, { "value": "&kp", "params": [{"value": "DOT"}] }, { "value": "&kp", "params": [{"value": "DOT"}] }, { "value": "&kp", "params": [{"value": "DOT"}] } ] },
  { "name": "&mac_arrow", "params": [], "description": "12. Arrow Macro: ->", "waitMs": 0, "tapMs": 0, "bindings": [ { "value": "&macro_tap", "params": [] }, { "value": "&kp", "params": [{"value": "MINUS"}] }, { "value": "&kp", "params": [{"value": "GT"}] } ] },
  { "name": "&mac_fat_arrow", "params": [], "description": "14. Fat Arrow Macro: =>", "waitMs": 0, "tapMs": 0, "bindings": [ { "value": "&macro_tap", "params": [] }, { "value": "&kp", "params": [{"value": "EQUAL"}] }, { "value": "&kp", "params": [{"value": "GT"}] } ] }
]) as $new_macros |

# --- 2. MOD-MORPHS ---
([
  { "name": "&mm_bspc_del", "params": [], "description": "1. God-Tier Thumb: Tap BSPC, Shift DEL", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "BSPC"}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "DEL"}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_esc_tilde", "params": [], "description": "6. Smart Esc Corner: Tap ESC, Shift ~", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "ESC"}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "GRAVE"}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_tab_bck", "params": [], "description": "8. App Switcher: Tap TAB, Shift Shift+TAB", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "TAB"}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "LS", "params": [{"value": "TAB"}]}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_dot_colon", "params": [], "description": "9. Punctuation: Tap '.', Shift ':'", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "DOT"}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "COLON"}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_paren_angle", "params": [], "description": "10. Nested Brackets: Tap '(', Shift '<'", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "LPAR"}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "LT"}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_brack_brace", "params": [], "description": "10. Nested Brackets: Tap '[', Shift '{'", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "LBKT"}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "LBRC"}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_slash_qmark", "params": [], "description": "11. Question & Excl: Tap '/', Shift '?'", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "FSLH"}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "QMARK"}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_dash_under", "params": [], "description": "12. Dash & Arrow: Tap '-', Shift '_'", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "MINUS"}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "UNDER"}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_eq_plus", "params": [], "description": "14. Math Operator: Tap '=', Shift '+'", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "EQUAL"}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "PLUS"}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_pscrn_snip", "params": [], "description": "15. OS Screenshot: Tap PRT, Shift Snip", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "PSCRN"}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "LG", "params": [{"value": "LS", "params": [{"value": "S"}]}]}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] }
]) as $new_morphs |

# --- 3. TAP-DANCES ---
([
  { "name": "&td_spc_tog", "params": [], "description": "2. Peek-or-Lock Layer Space", "tappingTermMs": 200, "bindings": [ { "value": "&kp", "params": [{"value": "SPACE"}] }, { "value": "&tog", "params": [{"value": 1}] } ] },
  { "name": "&td_parens", "params": [], "description": "3. Space Cadet Evolved", "tappingTermMs": 200, "bindings": [ { "value": "&kp", "params": [{"value": "LPAR"}] }, { "value": "&kp", "params": [{"value": "RPAR"}] } ] },
  { "name": "&td_enter_eol", "params": [], "description": "4. Enter / Shift / End-of-Line Macro", "tappingTermMs": 200, "bindings": [ { "value": "&kp", "params": [{"value": "RET"}] }, { "value": "&mac_eol_semi", "params": [] } ] },
  { "name": "&td_hrm_escape_f", "params": [], "description": "5. Safe HRM Escape Hatch (F)", "tappingTermMs": 200, "bindings": [ { "value": "&kp", "params": [{"value": "F"}] }, { "value": "&kp", "params": [{"value": "F"}] } ] },
  { "name": "&td_caps_word", "params": [], "description": "7. Smart Caps Word Trigger", "tappingTermMs": 200, "bindings": [ { "value": "&kp", "params": [{"value": "LSHFT"}] }, { "value": "&caps_word", "params": [] } ] },
  { "name": "&td_punct_power", "params": [], "description": "9. Punctuation Powerhouse", "tappingTermMs": 200, "bindings": [ { "value": "&mm_dot_colon", "params": [] }, { "value": "&mac_ellipsis", "params": [] } ] },
  { "name": "&td_nested_brackets", "params": [], "description": "10. Coder's Nested Brackets", "tappingTermMs": 200, "bindings": [ { "value": "&mm_paren_angle", "params": [] }, { "value": "&mm_brack_brace", "params": [] } ] },
  { "name": "&td_quest_excl", "params": [], "description": "11. Smart Question & Exclamation", "tappingTermMs": 200, "bindings": [ { "value": "&mm_slash_qmark", "params": [] }, { "value": "&kp", "params": [{"value": "EXCL"}] } ] },
  { "name": "&td_dash_arrow", "params": [], "description": "12. Dash & Arrow Macro Key", "tappingTermMs": 200, "bindings": [ { "value": "&mm_dash_under", "params": [] }, { "value": "&mac_arrow", "params": [] } ] },
  { "name": "&td_media", "params": [], "description": "13. Media Maestro (1x Play, 2x Next, 3x Prev)", "tappingTermMs": 200, "bindings": [ { "value": "&kp", "params": [{"value": "C_PP"}] }, { "value": "&kp", "params": [{"value": "C_NEXT"}] }, { "value": "&kp", "params": [{"value": "C_PREV"}] } ] },
  { "name": "&td_math_logic", "params": [], "description": "14. Math & Logic Operator", "tappingTermMs": 200, "bindings": [ { "value": "&mm_eq_plus", "params": [] }, { "value": "&mac_fat_arrow", "params": [] } ] },
  { "name": "&td_power_screen", "params": [], "description": "15. OS Power & Screenshot Key", "tappingTermMs": 200, "bindings": [ { "value": "&mm_pscrn_snip", "params": [] }, { "value": "&kp", "params": [{"value": "C_SLEEP"}] } ] }
]) as $new_dances |

# --- 4. HOLD-TAPS ---
([
  { "name": "&ht_thumb_bspc", "params": [], "description": "1. God-Tier Thumb Backspace", "bindings": [ "&mo", "&mm_bspc_del" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_spc_peek_lock", "params": [], "description": "2. Peek-or-Lock Layer Space", "bindings": [ "&mo", "&td_spc_tog" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_space_cadet", "params": [], "description": "3. Space Cadet Evolved", "bindings": [ "&kp", "&td_parens" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_shift_enter", "params": [], "description": "4. Enter / Shift / End-of-Line Macro", "bindings": [ "&kp", "&td_enter_eol" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_hrm_safe", "params": [], "description": "5. Safe HRM Escape Hatch", "bindings": [ "&kp", "&td_hrm_escape_f" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_ctrl_esc", "params": [], "description": "6. 40% Smart Escape Corner", "bindings": [ "&kp", "&mm_esc_tilde" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_shift_caps", "params": [], "description": "7. Smart Caps Word Trigger", "bindings": [ "&kp", "&td_caps_word" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_alt_tab", "params": [], "description": "8. App Switcher Engine", "bindings": [ "&kp", "&mm_tab_bck" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_vol_media", "params": [], "description": "13. Media Maestro", "bindings": [ "&kp", "&td_media" ], "tappingTermMs": 200, "flavor": "tap-preferred" }
]) as $new_holds |

# --- 5. SAFE MERGE INJECTION ---
(.keymap // .) |= (
  .macros    = ($new_macros + (.macros // []) | unique_by(.name)) |
  .modMorphs = ($new_morphs + (.modMorphs // []) | unique_by(.name)) |
  .tapDances = ($new_dances + (.tapDances // []) | unique_by(.name)) |
  .holdTaps  = ($new_holds  + (.holdTaps  // []) | unique_by(.name))
)
"""

# ==============================================================================
# METADATA & CONFIG
# ==============================================================================

[manifest]
author = "moosyresearch"
keyboards = ["go60", "glove80"]
icon = "🏆"
theme = "green"

[config]
category = "Test"
