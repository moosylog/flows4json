uid = "gb_symbol"
type = "mutation"
language = "gb"
title = "Symbols 2 UK English"
subtitle = "🌍 Map en-US to en-GB"
description = """
When you change the language settings in the MoErgo Layout Editor from the default US English keyboard layout (en-US) to UK English (en-GB), some symbols no longer match their expected characters.

This flow remaps those symbols so they produce the correct characters for the UK Windows/Linux layout.

⚠️ **Required:** Symbol Layer must be included in your layout.

🤖 **Quality note:** The symbol mappings aren’t created by humans, they’re generated by the machines.

"""
script = """
# ==============================================================================
#             UK ENGLISH SYMBOL MAPPER (For MoErgo Layout Editor / ZMK)
#             OS TARGET: WINDOWS / LINUX (Standard ISO / en-GB)
# ==============================================================================

{
  # --- Quotes & At Sign (@ / ") ---
  "AT":                  [{"value": "LS", "params": [{"value": "SQT", "params": []}]}],           # @ -> Shift + '
  "LS(N2)":              [{"value": "LS", "params": [{"value": "SQT", "params": []}]}],             
  "DQT":                 [{"value": "LS", "params": [{"value": "N2", "params": []}]}],            # " -> Shift + 2
  "LS(SINGLE_QUOTE)":    [{"value": "LS", "params": [{"value": "N2", "params": []}]}],            
  "LS(SQT)":             [{"value": "LS", "params": [{"value": "N2", "params": []}]}],            

  # --- Hash & Tilde (# / ~) ---
  "HASH":                [{"value": "NON_US_HASH", "params": []}],                                # # -> # key (ISO)
  "LS(N3)":              [{"value": "NON_US_HASH", "params": []}],                                
  "TILDE":               [{"value": "LS", "params": [{"value": "NON_US_HASH", "params": []}]}],   # ~ -> Shift + #
  "LS(GRAVE)":           [{"value": "LS", "params": [{"value": "NON_US_HASH", "params": []}]}],          

  # --- Slashes & Pipes (\\ / |) ---
  "BSLH":                [{"value": "NON_US_BSLH", "params": []}],                                # \\ -> \\ key (ISO)
  "PIPE":                [{"value": "LS", "params": [{"value": "NON_US_BSLH", "params": []}]}],   # | -> Shift + \\
  "LS(BSLH)":            [{"value": "LS", "params": [{"value": "NON_US_BSLH", "params": []}]}]   
} as $uk_symbol_map |

# ==============================================================================
# CONFIGURATION TARGETS
# ==============================================================================

.locale = "en-GB" |
"Symbol" as $layer_to_translate |

# ==============================================================================
# BEHIND-THE-SCENES TRANSLATION ENGINE
# ==============================================================================

(.layer_names // .keymap.layer_names) as $all_layers |

if $all_layers == null then
  "Error: Could not find any keyboard layer names in this file." | halt_error
else
  ($all_layers | index($layer_to_translate)) as $layer_index |

  if $layer_index == null then
    "Error: The layer named '\\($layer_to_translate)' does not exist." | halt_error
  else
    # Outer logic block structures modifications correctly for standard JQ environments
    if .keymap.layers then
      .keymap.layers[$layer_index] |= map(
        if . == null or .value != "&kp" or .params == null or .params == [] then 
          .
        else
          (.params[0] | if .params == null or .params == [] then .value else "\\(.value)(\\(.params[0].value))" end) as $current_key |
          if $uk_symbol_map[$current_key] then .params = $uk_symbol_map[$current_key] else . end
        end
      )
    else
      .layers[$layer_index] |= map(
        if . == null or .value != "&kp" or .params == null or .params == [] then 
          .
        else
          (.params[0] | if .params == null or .params == [] then .value else "\\(.value)(\\(.params[0].value))" end) as $current_key |
          if $uk_symbol_map[$current_key] then .params = $uk_symbol_map[$current_key] else . end
        end
      )
    end
  end
end
"""
[manifest]
author = "moosyresearch"
keyboards = ["go60","glove80"]
icon = "🇬🇧"      
# Optional: red, green, blue, purple, yellow, orange
theme = "blue" 
[config]
category = "Symbols"
num = 123
