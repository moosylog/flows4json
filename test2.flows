uid = "top_15_zmk_behaviors"
type = "mutation"
language = "en-US"
title = "Test2"
subtitle = "Community Vetted Tap-Dances & Mod-Morphs"
description = """
Injects the **Top 15 Community-Vetted Use Cases** directly into your layout dictionary.

These combinations condense punctuation, macros, and layer toggles into highly optimized keys without disrupting your typing rhythm.

> **Community Golden Rule:** *Mod-Morph* is highly preferred for alphanumeric keys because it executes instantly. *Tap-Dance* introduces a slight tapping delay, making it better suited for thumb keys, outer columns, macros, and layer toggles where rapid typing rhythm isn't affected.

**Includes:**
* **9 Hold-Taps** (e.g., God-Tier Thumb Backspace, Media Maestro)
* **10 Mod-Morphs** (e.g., Smart Escape Corner, Punctuation Powerhouse)
* **12 Tap-Dances** (e.g., Peek-or-Lock Layer Space, Nested Brackets)
* **4 Macros** (e.g., End-of-Line, Arrow Operator)

*If "Implement on layer0" is YES, it will automatically seek out keys like `BSPC`, `SPACE`, `/`, etc., on your base layer and seamlessly upgrade them to these new behaviors!*
"""

# ==============================================================================
# JQ SCRIPT
# ==============================================================================
script = """
# ZMK Autonomous Injection Script - "Top 15 Advanced Behaviors" (V7 - AST Strict Auto-Bind)

# --- PRE-REQUISITE: RESOLVE TARGET LAYERS ---
(if $auto_bind == "yes" then
  (
    ["Nav", "Num"] as $req_layers |
    .layer_names |= (. // ["Base"]) |
    .layers |= (. // [[]]) |
    (.layers[0] | length) as $layer_size |
    reduce $req_layers[] as $name (.;
      if (.layer_names | index($name) == null) then
        .layer_names += [$name] |
        .layers += [[range(0; $layer_size) | {"value": "&trans"}]]
      else . end
    )
  )
else . end) |

(.layer_names | index("Nav") // 1) as $idx_nav |
(.layer_names | index("Num") // 2) as $idx_num |


# ==============================================================================
# STEP 1: CREATE BEHAVIORS (Always executes)
# ==============================================================================

([
  { "name": "&mac_eol_semi", "params": [], "description": "4. End of Line Macro: End + ; + Enter", "waitMs": 0, "tapMs": 0, "bindings": [ { "value": "&macro_tap", "params": [] }, { "value": "&kp", "params": [{"value": "END", "params": []}] }, { "value": "&kp", "params": [{"value": "SEMI", "params": []}] }, { "value": "&kp", "params": [{"value": "RET", "params": []}] } ] },
  { "name": "&mac_ellipsis", "params": [], "description": "9. Ellipsis Macro: ...", "waitMs": 0, "tapMs": 0, "bindings": [ { "value": "&macro_tap", "params": [] }, { "value": "&kp", "params": [{"value": "DOT", "params": []}] }, { "value": "&kp", "params": [{"value": "DOT", "params": []}] }, { "value": "&kp", "params": [{"value": "DOT", "params": []}] } ] },
  { "name": "&mac_arrow", "params": [], "description": "12. Arrow Macro: ->", "waitMs": 0, "tapMs": 0, "bindings": [ { "value": "&macro_tap", "params": [] }, { "value": "&kp", "params": [{"value": "MINUS", "params": []}] }, { "value": "&kp", "params": [{"value": "GT", "params": []}] } ] },
  { "name": "&mac_fat_arrow", "params": [], "description": "14. Fat Arrow Macro: =>", "waitMs": 0, "tapMs": 0, "bindings": [ { "value": "&macro_tap", "params": [] }, { "value": "&kp", "params": [{"value": "EQUAL", "params": []}] }, { "value": "&kp", "params": [{"value": "GT", "params": []}] } ] }
]) as $new_macros |

([
  { "name": "&mm_bspc_del", "description": "1. God-Tier Thumb: Tap BSPC, Shift DEL", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "BSPC", "params": []}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "DEL", "params": []}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_esc_tilde", "description": "6. Smart Esc Corner: Tap ESC, Shift ~", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "ESC", "params": []}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "GRAVE", "params": []}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_tab_bck", "description": "8. App Switcher: Tap TAB, Shift Shift+TAB", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "TAB", "params": []}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "LS", "params": [{"value": "TAB", "params": []}]}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_dot_colon", "description": "9. Punctuation: Tap '.', Shift ':'", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "DOT", "params": []}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "COLON", "params": []}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_paren_angle", "description": "10. Nested Brackets: Tap '(', Shift '<'", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "LPAR", "params": []}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "LT", "params": []}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_brack_brace", "description": "10. Nested Brackets: Tap '[', Shift '{'", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "LBKT", "params": []}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "LBRC", "params": []}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_slash_qmark", "description": "11. Question & Excl: Tap '/', Shift '?'", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "FSLH", "params": []}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "QMARK", "params": []}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_dash_under", "description": "12. Dash & Arrow: Tap '-', Shift '_'", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "MINUS", "params": []}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "UNDER", "params": []}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_eq_plus", "description": "14. Math Operator: Tap '=', Shift '+'", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "EQUAL", "params": []}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "PLUS", "params": []}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] },
  { "name": "&mm_pscrn_snip", "description": "15. OS Screenshot: Tap PRT, Shift Snip", "cases": [ { "binding": { "value": "&kp", "params": [{"value": "PSCRN", "params": []}] }, "mods": [], "keepMods": [] }, { "binding": { "value": "&kp", "params": [{"value": "LG", "params": [{"value": "LS", "params": [{"value": "S", "params": []}]}]}] }, "mods": ["MOD_LSFT", "MOD_RSFT"], "keepMods": [] } ] }
]) as $new_morphs |

([
  { "name": "&td_spc_tog", "description": "2. Peek-or-Lock Layer Space", "tappingTermMs": 200, "bindings": [ { "value": "&kp", "params": [{"value": "SPACE", "params": []}] }, { "value": "&tog", "params": [{"value": $idx_num}] } ] },
  { "name": "&td_parens", "description": "3. Space Cadet Evolved", "tappingTermMs": 200, "bindings": [ { "value": "&kp", "params": [{"value": "LPAR", "params": []}] }, { "value": "&kp", "params": [{"value": "RPAR", "params": []}] } ] },
  { "name": "&td_enter_eol", "description": "4. Enter / Shift / End-of-Line Macro", "tappingTermMs": 200, "bindings": [ { "value": "&kp", "params": [{"value": "RET", "params": []}] }, { "value": "&mac_eol_semi", "params": [] } ] },
  { "name": "&td_hrm_escape_f", "description": "5. Safe HRM Escape Hatch (F)", "tappingTermMs": 200, "bindings": [ { "value": "&kp", "params": [{"value": "F", "params": []}] }, { "value": "&kp", "params": [{"value": "F", "params": []}] } ] },
  { "name": "&td_caps_word", "description": "7. Smart Caps Word Trigger", "tappingTermMs": 200, "bindings": [ { "value": "&kp", "params": [{"value": "LSHFT", "params": []}] }, { "value": "&caps_word", "params": [] } ] },
  { "name": "&td_punct_power", "description": "9. Punctuation Powerhouse", "tappingTermMs": 200, "bindings": [ { "value": "&mm_dot_colon", "params": [] }, { "value": "&mac_ellipsis", "params": [] } ] },
  { "name": "&td_nested_brackets", "description": "10. Coder's Nested Brackets", "tappingTermMs": 200, "bindings": [ { "value": "&mm_paren_angle", "params": [] }, { "value": "&mm_brack_brace", "params": [] } ] },
  { "name": "&td_quest_excl", "description": "11. Smart Question & Exclamation", "tappingTermMs": 200, "bindings": [ { "value": "&mm_slash_qmark", "params": [] }, { "value": "&kp", "params": [{"value": "EXCL", "params": []}] } ] },
  { "name": "&td_dash_arrow", "description": "12. Dash & Arrow Macro Key", "tappingTermMs": 200, "bindings": [ { "value": "&mm_dash_under", "params": [] }, { "value": "&mac_arrow", "params": [] } ] },
  { "name": "&td_media", "description": "13. Media Maestro (1x Play, 2x Next, 3x Prev)", "tappingTermMs": 200, "bindings": [ { "value": "&kp", "params": [{"value": "C_PP", "params": []}] }, { "value": "&kp", "params": [{"value": "C_NEXT", "params": []}] }, { "value": "&kp", "params": [{"value": "C_PREV", "params": []}] } ] },
  { "name": "&td_math_logic", "description": "14. Math & Logic Operator", "tappingTermMs": 200, "bindings": [ { "value": "&mm_eq_plus", "params": [] }, { "value": "&mac_fat_arrow", "params": [] } ] },
  { "name": "&td_power_screen", "description": "15. OS Power & Screenshot Key", "tappingTermMs": 200, "bindings": [ { "value": "&mm_pscrn_snip", "params": [] }, { "value": "&kp", "params": [{"value": "C_SLEEP", "params": []}] } ] }
]) as $new_dances |

([
  { "name": "&ht_thumb_bspc", "description": "1. God-Tier Thumb Backspace", "bindings": [ "&mo", "&mm_bspc_del" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_spc_peek_lock", "description": "2. Peek-or-Lock Layer Space", "bindings": [ "&mo", "&td_spc_tog" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_space_cadet", "description": "3. Space Cadet Evolved", "bindings": [ "&kp", "&td_parens" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_shift_enter", "description": "4. Enter / Shift / End-of-Line Macro", "bindings": [ "&kp", "&td_enter_eol" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_hrm_safe", "description": "5. Safe HRM Escape Hatch", "bindings": [ "&kp", "&td_hrm_escape_f" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_ctrl_esc", "description": "6. 40% Smart Escape Corner", "bindings": [ "&kp", "&mm_esc_tilde" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_shift_caps", "description": "7. Smart Caps Word Trigger", "bindings": [ "&kp", "&td_caps_word" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_alt_tab", "description": "8. App Switcher Engine", "bindings": [ "&kp", "&mm_tab_bck" ], "tappingTermMs": 200, "flavor": "tap-preferred" },
  { "name": "&ht_vol_media", "description": "13. Media Maestro", "bindings": [ "&kp", "&td_media" ], "tappingTermMs": 200, "flavor": "tap-preferred" }
]) as $new_holds |

(.keymap // .) |= (
  .macros    = ($new_macros + (.macros // []) | unique_by(.name)) |
  .modMorphs = ($new_morphs + (.modMorphs // []) | unique_by(.name)) |
  .tapDances = ($new_dances + (.tapDances // []) | unique_by(.name)) |
  .holdTaps  = ($new_holds  + (.holdTaps  // []) | unique_by(.name)) |
  
  # ==============================================================================
  # STEP 2: AUTO-ASSIGN ON BASE LAYER (Only executes if YES)
  # ==============================================================================
  (if $auto_bind == "yes" and (.layers | length > 0) then
    {
      "BSPC":     {"value": "&ht_thumb_bspc", "params": [{"value": $idx_nav}]},
      "SPACE":    {"value": "&ht_spc_peek_lock", "params": [{"value": $idx_num}]},
      "RET":      {"value": "&ht_shift_enter", "params": [{"value": "RSHFT", "params": []}]},
      "DOT":      {"value": "&td_punct_power"},
      "LBKT":     {"value": "&td_nested_brackets"},
      "FSLH":     {"value": "&td_quest_excl"},
      "MINUS":    {"value": "&td_dash_arrow"},
      "EQUAL":    {"value": "&td_math_logic"},
      "ESC":      {"value": "&ht_ctrl_esc", "params": [{"value": "LCTRL", "params": []}]},
      "TAB":      {"value": "&ht_alt_tab", "params": [{"value": "LALT", "params": []}]},
      "C_VOL_UP": {"value": "&ht_vol_media", "params": [{"value": "C_VOL_UP", "params": []}]},
      "PSCRN":    {"value": "&td_power_screen"},
      "LSHFT":    {"value": "&ht_shift_caps", "params": [{"value": "LSHFT", "params": []}]}
    } as $map |
    
    .layers[0] |= map(
      if type == "object" and .value == "&kp" and .params and (.params | length > 0) and (.params[0].value | in($map)) then
        $map[.params[0].value] + (if .decoration then {decoration: .decoration} else {} end)
      else
        .
      end
    )
  else . end)
)
"""

# ==============================================================================
# UI PARAMETERS 
# ==============================================================================

[[param]]
id = "auto_bind"
label = "Implement on base layer (layer0)"
type = "select"
options = ["yes", "no"]
labels = ["Yes", "No"]
default = "yes"

# ==============================================================================
# METADATA & CONFIG
# ==============================================================================

[manifest]
author = "moosyresearch"
keyboards = ["go60", "glove80"]
icon = "🏆"
theme = "green"

[config]
category = "Test/Dev"
