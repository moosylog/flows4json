uid = "hrm_bil_adaptive"
type = "mutation"
language = "us"
title = "Sunaku's Bilateral HRM"
subtitle = "Adaptive for Glove80 & Go60"
description = """
Advanced home-row mods with bilateral combination enforcement.
"""

script = """
{
  "GACS": { "L1": "LGUI",  "R1": "RGUI",  "L2": "LCTRL", "R2": "RCTRL", "C1": "#d9f9c9", "C2":"#fbe6fe"  },
  "CAGS": { "L1": "LCTRL", "R1": "RCTRL", "L2": "LGUI",  "R2": "RGUI",  "C1": "#fbe6fe", "C2":"#d9f9c9"  }
}[$mod_preset] as $mod |

(.keymap.layers[0] // .layers[0]) as $base_layer |
($base_layer | length) as $len |

# ------------------------------------------------------------------------------
# 1. LAYER INITIALIZATION
# ------------------------------------------------------------------------------
(if .keymap then .keymap else . end) |= (
  
  (
    ["HRM_Bil", "LeftPinky", "LeftRingy", "LeftMiddy", "LeftIndex", "RightIndex", "RightMiddy", "RightRingy", "RightPinky"] as $req_layers |
    .layer_names |= (. // []) | .layers |= (. // []) |
    reduce $req_layers[] as $name (.; 
      if (.layer_names | index($name) == null) then 
        .layer_names += [$name] | 
        # Zod Safety: Pre-fill with exactly 80 or 60 transparent keys
        .layers += [[range($len) | {"value": "&trans", "params": []}]] 
      else . end
    )
  ) |

  (.layer_names | index("HRM_Bil")) as $idx_hrm |
  (.layer_names | index("LeftPinky")) as $idx_lp |
  (.layer_names | index("LeftRingy")) as $idx_lr |
  (.layer_names | index("LeftMiddy")) as $idx_lm |
  (.layer_names | index("LeftIndex")) as $idx_li |
  (.layer_names | index("RightIndex")) as $idx_ri |
  (.layer_names | index("RightMiddy")) as $idx_rm |
  (.layer_names | index("RightRingy")) as $idx_rr |
  (.layer_names | index("RightPinky")) as $idx_rp |

  # ------------------------------------------------------------------------------
  # 2. MACROS (Entity-Protected)
  # ------------------------------------------------------------------------------
  ("&ma" + "cro_press") as $m_press |
  ("&ma" + "cro_release") as $m_rel |
  ("&ma" + "cro_tap") as $m_tap |
  ("&ma" + "cro_param_1to1") as $m_p1 |
  ("&ma" + "cro_pause_for_release") as $m_pause |

  .macros = ((.macros // []) + [
    # PASTE ALL 16 MACROS EXPLICITLY HERE
    # Example showing preserved description and protected variables:
    {
      "name": "&HRM_left_index_hold_v1B_TKZ",
      "description": "HRM_left_index_hold -> swich layer  - TailorKey",
      "waitMs": 0, "tapMs": 0,
      "bindings": [
        {"value": $m_press}, {"value": $m_p1},
        {"value": "&kp", "params": [{"value": "A"}]},
        {"value": "&mo", "params": [{"value": $idx_li}]},
        {"value": $m_pause}, {"value": $m_rel}, {"value": $m_p1},
        {"value": "&kp", "params": [{"value": "A"}]},
        {"value": "&mo", "params": [{"value": $idx_li}]}
      ],
      "params": ["code"]
    }
    # ... insert remaining 15 macros here ...
  ] | unique_by(.name)) |

  # ------------------------------------------------------------------------------
  # 3. HOLD TAPS (Artisanal Tuning Preserved)
  # ------------------------------------------------------------------------------
  # We do NOT use .map() here. We explicitly define every object to preserve 
  # the unique requirePriorIdleMs timings and specific holdTriggerKeyPositions.
  
  .holdTaps = ((.holdTaps // []) + [
    # PASTE ALL 32 HOLD TAPS EXPLICITLY HERE
    # Example showing perfectly preserved metadata, timings, and custom matrices:
    {
      "name": "&HRM_left_index_middy_v1B_TKZ",
      "description": "HRM_left_index_middy_bilateral -> &kp - &HRM_left_index_tap - TailorKey",
      "bindings": ["&kp", "&HRM_left_index_tap_v1B_TKZ"],
      "tappingTermMs": 180,
      "flavor": "tap-preferred",
      "quickTapMs": 300,
      "requirePriorIdleMs": 100,
      "holdTriggerOnRelease": true,
      "holdTriggerKeyPositions": [57,56,55,72,73,74,5,6,7,8,16,17,18,19,20,28,29,30,31,32,40,41,42,43,44,58,59,60,61,62,75,76,77,78,9,21,33,45,63,79,52,53,54,70,71,69]
    },
    {
      "name": "&HRM_right_middy_pinky_v1B_TKZ",
      "description": "HRM_right_middy_pinky_bilateral -> &kp - &HRM_right_pinky_tap - TailorKey",
      "bindings": ["&kp", "&HRM_right_middy_tap_v1B_TKZ"],
      "tappingTermMs": 210,
      "flavor": "tap-preferred",
      "quickTapMs": 300,
      "requirePriorIdleMs": 150,
      "holdTriggerOnRelease": true,
      "holdTriggerKeyPositions": [0,10,22,46,64,65,47,52,51,39,27,15,4,3,2,1,11,23,35,34,48,66,69,70,71,54,53,55,56,57,74,73,72,68,67,49,50,38,26,14,13,25,37,24,12,36]
    }
    # ... insert remaining 30 hold taps here ...
  ] | unique_by(.name)) |

  # ------------------------------------------------------------------------------
  # 4. EXPLICIT MASKING LAYERS (Hardware Adaptive)
  # ------------------------------------------------------------------------------
  (
    if $len == 80 then
      # GLOVE80 EXPLICIT ARRAYS
      # Paste your exact 80-key arrays here to restore the "Ghost" layers.
      
      .layers[$idx_hrm] = [ /* Paste your 80 keys for HRM_Bil */ ] |
      .layers[$idx_lp]  = [ /* Paste your 80 keys for LeftPinky */ ] |
      .layers[$idx_lr]  = [ /* Paste your 80 keys for LeftRingy */ ] |
      .layers[$idx_lm]  = [ /* Paste your 80 keys for LeftMiddy */ ] |
      .layers[$idx_li]  = [ /* Paste your 80 keys for LeftIndex */ ] |
      .layers[$idx_ri]  = [ /* Paste your 80 keys for RightIndex */ ] |
      .layers[$idx_rm]  = [ /* Paste your 80 keys for RightMiddy */ ] |
      .layers[$idx_rr]  = [ /* Paste your 80 keys for RightRingy */ ] |
      .layers[$idx_rp]  = [ /* Paste your 80 keys for RightPinky */ ]

    elif $len == 60 then
      # GO60 EXPLICIT ARRAYS
      # To achieve the identical artisanal tuning for the Go60, you must 
      # provide the tailored 60-key arrays for the masking logic here.
      # Until then, Zod validation is safely satisfied by the 60 &trans 
      # keys injected during Step 1.
      .
      
    else . end
  )
)
"""

[[param]]
id = "mod_preset"
label = "Recommended order"
type = "select"
options = ["GACS", "CAGS"]
labels = ["Windows / Linux", "macOS"]
default = "GACS"
