uid = "hrm_bil_adaptive"
type = "mutation"
language = "us"
title = "Sunaku's Bilateral HRM"
subtitle = "Adaptive for Glove80 & Go60"
description = """
Advanced home-row mods with bilateral combination enforcement.

Generates the HRM layers dynamically by reading your Base Layer (Layer 0), meaning this perfectly adapts to QWERTY, Colemak, Dvorak, or custom layouts on **both** the Glove80 and Go60.
"""

# ==============================================================================
# JQ SCRIPT
# ==============================================================================
script = """
{
  "GACS": { "L1": "LGUI",  "R1": "RGUI",  "L2": "LCTRL", "R2": "RCTRL", "C1": "#d9f9c9", "C2":"#fbe6fe"  },
  "CAGS": { "L1": "LCTRL", "R1": "RCTRL", "L2": "LGUI",  "R2": "RGUI",  "C1": "#fbe6fe", "C2":"#d9f9c9"  }
}[$mod_preset] as $mod |

# ------------------------------------------------------------------------------
# 1. GEOMETRY ENGINE: Detect Hardware based on Layer 0 Length
# ------------------------------------------------------------------------------
(.keymap.layers[0] // .layers[0]) as $base_layer |
($base_layer | length) as $len |

(if $len == 80 then
  {
    "name": "Glove80",
    "hr": [35, 36, 37, 38, 41, 42, 43, 44],
    "left_side_keys": [0,10,22,34,46,64,65,47,35,23,1,2,12,11,24,36,48,66,67,49,37,25,13,3,4,14,15,27,26,38,39,51,50,68,52,53,54,71,70,69,55,56,57,74,73,72],
    "right_side_keys": [57,56,55,72,73,74,5,6,7,8,16,17,18,19,20,28,29,30,31,32,40,41,42,43,44,58,59,60,61,62,75,76,77,78,9,21,33,45,63,79,52,53,54,70,71,69]
  }
else
  {
    "name": "Go60",
    "hr": [24, 25, 26, 27, 32, 33, 34, 35],
    "left_side_keys": [0,1,2,3,4,5, 12,13,14,15,16,17, 24,25,26,27,28,29, 36,37,38,39,40,41, 48,49,50,51,52,53],
    "right_side_keys": [6,7,8,9,10,11, 18,19,20,21,22,23, 30,31,32,33,34,35, 42,43,44,45,46,47, 54,55,56,57,58,59]
  }
end) as $geo |

# ------------------------------------------------------------------------------
# 2. LAYER SETUP & INDEXING
# ------------------------------------------------------------------------------
(if .keymap then .keymap else . end) |= (
  
  (
    ["HRM_Bil", "LeftPinky", "LeftRingy", "LeftMiddy", "LeftIndex", "RightIndex", "RightMiddy", "RightRingy", "RightPinky"] as $req_layers |
    .layer_names |= (. // []) | .layers |= (. // []) |
    reduce $req_layers[] as $name (.; 
      if (.layer_names | index($name) == null) then 
        .layer_names += [$name] | 
        .layers += [[range($len) | {"value": "&trans", "params": []}]] 
      else . end
    )
  ) |

  (.layer_names | index("HRM_Bil")) as $idx_hrm |
  (.layer_names | index("LeftPinky")) as $idx_lp |
  (.layer_names | index("LeftRingy")) as $idx_lr |
  (.layer_names | index("LeftMiddy")) as $idx_lm |
  (.layer_names | index("LeftIndex")) as $idx_li |
  (.layer_names | index("RightIndex")) as $idx_ri |
  (.layer_names | index("RightMiddy")) as $idx_rm |
  (.layer_names | index("RightRingy")) as $idx_rr |
  (.layer_names | index("RightPinky")) as $idx_rp |

  # ------------------------------------------------------------------------------
  # 3. TOPOLOGICAL BEHAVIOR INJECTION (Macros -> HoldTaps)
  # ------------------------------------------------------------------------------
  
# A. MACROS (Protected against HTML Entity Decoding)
  ("&ma" + "cro_press") as $m_press |
  ("&ma" + "cro_release") as $m_rel |
  ("&ma" + "cro_tap") as $m_tap |
  ("&ma" + "cro_param_1to1") as $m_p1 |
  ("&ma" + "cro_pause_for_release") as $m_pause |

  .macros = ((.macros // []) + [
    {"name":"&HRM_left_index_hold_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_press},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_li}]},{"value":$m_pause},{"value":$m_rel},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_li}]}],"params":["code"]},
    {"name":"&HRM_left_index_tap_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_rel},{"value":"&kp","params":[{"value":"LSHFT"}]},{"value":"&kp","params":[{"value":"RSHFT"}]},{"value":"&kp","params":[{"value":"LALT"}]},{"value":"&kp","params":[{"value":"RALT"}]},{"value":"&kp","params":[{"value":$mod.L2}]},{"value":"&kp","params":[{"value":$mod.R2}]},{"value":"&kp","params":[{"value":$mod.L1}]},{"value":"&kp","params":[{"value":$mod.R1}]},{"value":$m_tap},{"value":"&kp","params":[{"value":"F"}]},{"value":$m_tap},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]}],"params":["code"]},
    {"name":"&HRM_left_middy_hold_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_press},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_lm}]},{"value":$m_pause},{"value":$m_rel},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_lm}]}],"params":["code"]},
    {"name":"&HRM_left_middy_tap_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_rel},{"value":"&kp","params":[{"value":"LSHFT"}]},{"value":"&kp","params":[{"value":"RSHFT"}]},{"value":"&kp","params":[{"value":"LALT"}]},{"value":"&kp","params":[{"value":"RALT"}]},{"value":"&kp","params":[{"value":$mod.L2}]},{"value":"&kp","params":[{"value":$mod.R2}]},{"value":"&kp","params":[{"value":$mod.L1}]},{"value":"&kp","params":[{"value":$mod.R1}]},{"value":$m_tap},{"value":"&kp","params":[{"value":"D"}]},{"value":$m_tap},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]}],"params":["code"]},
    {"name":"&HRM_left_pinky_hold_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_press},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_lp}]},{"value":$m_pause},{"value":$m_rel},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_lp}]}],"params":["code"]},
    {"name":"&HRM_left_pinky_tap_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_rel},{"value":"&kp","params":[{"value":"LSHFT"}]},{"value":"&kp","params":[{"value":"RSHFT"}]},{"value":"&kp","params":[{"value":"LALT"}]},{"value":"&kp","params":[{"value":"RALT"}]},{"value":"&kp","params":[{"value":$mod.L2}]},{"value":"&kp","params":[{"value":$mod.R2}]},{"value":"&kp","params":[{"value":$mod.L1}]},{"value":"&kp","params":[{"value":$mod.R1}]},{"value":$m_tap},{"value":"&kp","params":[{"value":"A"}]},{"value":$m_tap},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]}],"params":["code"]},
    {"name":"&HRM_left_ring_hold_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_press},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_lr}]},{"value":$m_pause},{"value":$m_rel},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_lr}]}],"params":["code"]},
    {"name":"&HRM_left_ring_tap_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_rel},{"value":"&kp","params":[{"value":"LSHFT"}]},{"value":"&kp","params":[{"value":"RSHFT"}]},{"value":"&kp","params":[{"value":"LALT"}]},{"value":"&kp","params":[{"value":"RALT"}]},{"value":"&kp","params":[{"value":$mod.L2}]},{"value":"&kp","params":[{"value":$mod.R2}]},{"value":"&kp","params":[{"value":$mod.L1}]},{"value":"&kp","params":[{"value":$mod.R1}]},{"value":$m_tap},{"value":"&kp","params":[{"value":"S"}]},{"value":$m_tap},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]}],"params":["code"]},
    {"name":"&HRM_right_index_hold_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_press},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_ri}]},{"value":$m_pause},{"value":$m_rel},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_ri}]}],"params":["code"]},
    {"name":"&HRM_right_index_tap_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_rel},{"value":"&kp","params":[{"value":"LSHFT"}]},{"value":"&kp","params":[{"value":"RSHFT"}]},{"value":"&kp","params":[{"value":"LALT"}]},{"value":"&kp","params":[{"value":"RALT"}]},{"value":"&kp","params":[{"value":$mod.L2}]},{"value":"&kp","params":[{"value":$mod.R2}]},{"value":"&kp","params":[{"value":$mod.L1}]},{"value":"&kp","params":[{"value":$mod.R1}]},{"value":$m_tap},{"value":"&kp","params":[{"value":"J"}]},{"value":$m_tap},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]}],"params":["code"]},
    {"name":"&HRM_right_middy_hold_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_press},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_rm}]},{"value":$m_pause},{"value":$m_rel},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_rm}]}],"params":["code"]},
    {"name":"&HRM_right_middy_tap_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_rel},{"value":"&kp","params":[{"value":"LSHFT"}]},{"value":"&kp","params":[{"value":"RSHFT"}]},{"value":"&kp","params":[{"value":"LALT"}]},{"value":"&kp","params":[{"value":"RALT"}]},{"value":"&kp","params":[{"value":$mod.L2}]},{"value":"&kp","params":[{"value":$mod.R2}]},{"value":"&kp","params":[{"value":$mod.L1}]},{"value":"&kp","params":[{"value":$mod.R1}]},{"value":$m_tap},{"value":"&kp","params":[{"value":"K"}]},{"value":$m_tap},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]}],"params":["code"]},
    {"name":"&HRM_right_pinky_hold_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_press},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_rp}]},{"value":$m_pause},{"value":$m_rel},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_rp}]}],"params":["code"]},
    {"name":"&HRM_right_pinky_tap_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_rel},{"value":"&kp","params":[{"value":"LSHFT"}]},{"value":"&kp","params":[{"value":"RSHFT"}]},{"value":"&kp","params":[{"value":"LALT"}]},{"value":"&kp","params":[{"value":"RALT"}]},{"value":"&kp","params":[{"value":$mod.L2}]},{"value":"&kp","params":[{"value":$mod.R2}]},{"value":"&kp","params":[{"value":$mod.L1}]},{"value":"&kp","params":[{"value":$mod.R1}]},{"value":$m_tap},{"value":"&kp","params":[{"value":"SEMI"}]},{"value":$m_tap},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]}],"params":["code"]},
    {"name":"&HRM_right_ring_hold_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_press},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_rr}]},{"value":$m_pause},{"value":$m_rel},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]},{"value":"&mo","params":[{"value":$idx_rr}]}],"params":["code"]},
    {"name":"&HRM_right_ring_tap_v1B_TKZ","waitMs":0,"tapMs":0,"bindings":[{"value":$m_rel},{"value":"&kp","params":[{"value":"LSHFT"}]},{"value":"&kp","params":[{"value":"RSHFT"}]},{"value":"&kp","params":[{"value":"LALT"}]},{"value":"&kp","params":[{"value":"RALT"}]},{"value":"&kp","params":[{"value":$mod.L2}]},{"value":"&kp","params":[{"value":$mod.R2}]},{"value":"&kp","params":[{"value":$mod.L1}]},{"value":"&kp","params":[{"value":$mod.R1}]},{"value":$m_tap},{"value":"&kp","params":[{"value":"L"}]},{"value":$m_tap},{"value":$m_p1},{"value":"&kp","params":[{"value":"A"}]}],"params":["code"]}
  ] | unique_by(.name)) |

  # B. HOLD-TAPS (Dynamically mapping triggers based on $geo!)
  .holdTaps = ((.holdTaps // []) + (
    [
      {"name":"&HRM_left_index_middy_v1B_TKZ","bindings":["&kp","&HRM_left_index_tap_v1B_TKZ"],"tappingTermMs":180},
      {"name":"&HRM_left_index_pinky_v1B_TKZ","bindings":["&kp","&HRM_left_index_tap_v1B_TKZ"],"tappingTermMs":180},
      {"name":"&HRM_left_index_ringv1_TKZ","bindings":["&kp","&HRM_left_index_tap_v1B_TKZ"],"tappingTermMs":180},
      {"name":"&HRM_left_index_v1B_TKZ","bindings":["&HRM_left_index_hold_v1B_TKZ","&kp"],"tappingTermMs":180},
      {"name":"&HRM_left_middy_index_v1B_TKZ","bindings":["&kp","&HRM_left_middy_tap_v1B_TKZ"],"tappingTermMs":210},
      {"name":"&HRM_left_middy_pinky_v1B_TKZ","bindings":["&kp","&HRM_left_middy_tap_v1B_TKZ"],"tappingTermMs":210},
      {"name":"&HRM_left_middy_ring_v1B_TKZ","bindings":["&kp","&HRM_left_middy_tap_v1B_TKZ"],"tappingTermMs":210},
      {"name":"&HRM_left_middy_v1B_TKZ","bindings":["&HRM_left_middy_hold_v1B_TKZ","&kp"],"tappingTermMs":210},
      {"name":"&HRM_left_pinky_index_v1B_TKZ","bindings":["&kp","&HRM_left_pinky_tap_v1B_TKZ"],"tappingTermMs":270},
      {"name":"&HRM_left_pinky_middy_v1B_TKZ","bindings":["&kp","&HRM_left_pinky_tap_v1B_TKZ"],"tappingTermMs":270},
      {"name":"&HRM_left_pinky_ring_v1B_TKZ","bindings":["&kp","&HRM_left_pinky_tap_v1B_TKZ"],"tappingTermMs":270},
      {"name":"&HRM_left_pinky_v1B_TKZ","bindings":["&HRM_left_pinky_hold_v1B_TKZ","&kp"],"tappingTermMs":270},
      {"name":"&HRM_left_ring_index_v1B_TKZ","bindings":["&kp","&HRM_left_ring_tap_v1B_TKZ"],"tappingTermMs":240},
      {"name":"&HRM_left_ring_middy_v1B_TKZ","bindings":["&kp","&HRM_left_ring_tap_v1B_TKZ"],"tappingTermMs":240},
      {"name":"&HRM_left_ring_pinky_v1B_TKZ","bindings":["&kp","&HRM_left_ring_tap_v1B_TKZ"],"tappingTermMs":240},
      {"name":"&HRM_left_ring_v1B_TKZ","bindings":["&HRM_left_ring_hold_v1B_TKZ","&kp"],"tappingTermMs":240},
      {"name":"&HRM_right_index_middy_v1B_TKZ","bindings":["&kp","&HRM_right_index_tap_v1B_TKZ"],"tappingTermMs":180},
      {"name":"&HRM_right_index_pinky_v1B_TKZ","bindings":["&kp","&HRM_right_index_tap_v1B_TKZ"],"tappingTermMs":180},
      {"name":"&HRM_right_index_ring_v1B_TKZ","bindings":["&kp","&HRM_right_index_tap_v1B_TKZ"],"tappingTermMs":180},
      {"name":"&HRM_right_index_v1B_TKZ","bindings":["&HRM_right_index_hold_v1B_TKZ","&kp"],"tappingTermMs":180},
      {"name":"&HRM_right_middy_index_v1B_TKZ","bindings":["&kp","&HRM_right_middy_tap_v1B_TKZ"],"tappingTermMs":210},
      {"name":"&HRM_right_middy_pinky_v1B_TKZ","bindings":["&kp","&HRM_right_middy_tap_v1B_TKZ"],"tappingTermMs":210},
      {"name":"&HRM_right_middy_ring_v1B_TKZ","bindings":["&kp","&HRM_right_middy_tap_v1B_TKZ"],"tappingTermMs":210},
      {"name":"&HRM_right_middy_v1B_TKZ","bindings":["&HRM_right_middy_hold_v1B_TKZ","&kp"],"tappingTermMs":210},
      {"name":"&HRM_right_pinky_index_v1B_TKZ","bindings":["&kp","&HRM_right_pinky_tap_v1B_TKZ"],"tappingTermMs":270},
      {"name":"&HRM_right_pinky_middy_v1B_TKZ","bindings":["&kp","&HRM_right_pinky_tap_v1B_TKZ"],"tappingTermMs":270},
      {"name":"&HRM_right_pinky_ring_v1B_TKZ","bindings":["&kp","&HRM_right_pinky_tap_v1B_TKZ"],"tappingTermMs":270},
      {"name":"&HRM_right_pinky_v1B_TKZ","bindings":["&HRM_right_pinky_hold_v1B_TKZ","&kp"],"tappingTermMs":270},
      {"name":"&HRM_right_ring_index_v1B_TKZ","bindings":["&kp","&HRM_right_ring_tap_v1B_TKZ"],"tappingTermMs":240},
      {"name":"&HRM_right_ring_middy_v1B_TKZ","bindings":["&kp","&HRM_right_ring_tap_v1B_TKZ"],"tappingTermMs":240},
      {"name":"&HRM_right_ring_pinky_v1B_TKZ","bindings":["&kp","&HRM_right_ring_tap_v1B_TKZ"],"tappingTermMs":240},
      {"name":"&HRM_right_ring_v1B_TKZ","bindings":["&HRM_right_ring_hold_v1B_TKZ","&kp"],"tappingTermMs":240}
    ] | map({
      name: .name,
      bindings: .bindings,
      tappingTermMs: .tappingTermMs,
      flavor: "tap-preferred",
      quickTapMs: 300,
      requirePriorIdleMs: 150,
      holdTriggerOnRelease: true,
      holdTriggerKeyPositions: (if (.name | test("_left_")) then $geo.right_side_keys else $geo.left_side_keys end)
    })
  ) | unique_by(.name)) |

  # ------------------------------------------------------------------------------
  # 4. DYNAMIC LAYER GENERATOR (Depends on Hold-Taps & Macros)
  # ------------------------------------------------------------------------------
  .layers[$idx_hrm] = [
    range($len) as $i |
    $base_layer[$i] as $k |
    (if ($k | type == "object") then ($k.params[0].value // "") else ($k | tostring) end) as $val |

    if   $i == $geo.hr[0] then { "value": "&HRM_left_pinky_v1B_TKZ", "params": [{"value": $mod.L1}, {"value": $val}], "decoration": {"background": $mod.C2} }
    elif $i == $geo.hr[1] then { "value": "&HRM_left_ring_v1B_TKZ",  "params": [{"value": "LALT"},  {"value": $val}], "decoration": {"background": "#e5feff"} }
    elif $i == $geo.hr[2] then { "value": "&HRM_left_middy_v1B_TKZ", "params": [{"value": $mod.L2}, {"value": $val}], "decoration": {"background": $mod.C1} }
    elif $i == $geo.hr[3] then { "value": "&HRM_left_index_v1B_TKZ", "params": [{"value": "LSHFT"}, {"value": $val}], "decoration": {"background": "#fffec9"} }
    
    elif $i == $geo.hr[4] then { "value": "&HRM_right_index_v1B_TKZ","params": [{"value": "RSHFT"}, {"value": $val}], "decoration": {"background": "#fffec9"} }
    elif $i == $geo.hr[5] then { "value": "&HRM_right_middy_v1B_TKZ","params": [{"value": $mod.R2}, {"value": $val}], "decoration": {"background": $mod.C1} }
    elif $i == $geo.hr[6] then { "value": "&HRM_right_ring_v1B_TKZ", "params": [{"value": "LALT"},  {"value": $val}], "decoration": {"background": "#e5feff"} }
    elif $i == $geo.hr[7] then { "value": "&HRM_right_pinky_v1B_TKZ","params": [{"value": $mod.R1}, {"value": $val}], "decoration": {"background": $mod.C2} }
    
    else $k end
  ]
)
"""

# ==============================================================================
# UI PARAMETERS 
# ==============================================================================

[[param]]
id = "mod_preset"
label = "Recommended order"
type = "select"
options = ["GACS", "CAGS"]
labels = ["Windows / Linux", "macOS"]
default = "GACS"

[manifest]
author = "moosyresearch"
keyboards = ["go60", "glove80"]
icon = "📦"        
theme = "red" 
[config]
category = "Test/Dev"
