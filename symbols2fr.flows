uid = "fr_symbol"
type = "mutation"
language = "us"
title = "Symbols 2 French AZERTY"
subtitle = "🌍 Map en-US to fr-FR"
description = """
When you change the language settings in the MoErgo Layout Editor from the default US English keyboard layout (en-US) to French (fr-FR), some symbols no longer match their expected characters.

This flow remaps those symbols so they produce the correct characters for the French layout.

⚠️ **Required:** Symbol Layer must be included in your layout.

🤖 **Quality note:** The symbol mappings aren’t created by humans, they’re generated by the machines.

"""
script = """
# ==============================================================================
#             FRENCH SYMBOL MAPPER (For MoErgo Layout Editor / ZMK)
#             OS TARGET: WINDOWS / LINUX (Standard ISO / fr-FR)
# ==============================================================================
# 
# WELCOME! This script translates your "Symbol" layer keys for a French AZERTY OS.
# Maps aliases (e.g., SQT/SINGLE_QUOTE) to prevent any normalization bugs.
# ==============================================================================

{
  # --- Punctuation & Basics ---
  "DOT":                 [{"value": "LS", "params": [{"value": "COMMA", "params": []}]}],         # . -> Shift + ; key (US COMMA position)
  "COMMA":               [{"value": "M", "params": []}],                                          # , -> , key (US M position)
  "MINUS":               [{"value": "N6", "params": []}],                                         # - -> - key (US N6)
  "EQUAL":               [{"value": "EQUAL", "params": []}],                                      # = -> = key (US EQUAL)

  # --- Brackets & Braces ---
  "LPAR":                [{"value": "N5", "params": []}],                                         # ( -> ( key (US N5)
  "LS(N9)":              [{"value": "N5", "params": []}],            
  "RPAR":                [{"value": "MINUS", "params": []}],                                      # ) -> ) key (US MINUS position)
  "LS(N0)":              [{"value": "MINUS", "params": []}],            
  "LBKT":                [{"value": "RA", "params": [{"value": "N5", "params": []}]}],            # [ -> AltGr + 5
  "RBKT":                [{"value": "RA", "params": [{"value": "MINUS", "params": []}]}],          # ] -> AltGr + ) (US MINUS position)
  "LBRC":                [{"value": "RA", "params": [{"value": "N4", "params": []}]}],            # { -> AltGr + 4
  "LS(LBKT)":            [{"value": "RA", "params": [{"value": "N4", "params": []}]}],            
  "RBRC":                [{"value": "RA", "params": [{"value": "EQUAL", "params": []}]}],          # } -> AltGr + = (US EQUAL position)
  "LS(RBKT)":            [{"value": "RA", "params": [{"value": "EQUAL", "params": []}]}],            
  "LT":                  [{"value": "NON_US_BSLH", "params": []}],                                # < -> < key (next to L-Shift)
  "LS(COMMA)":           [{"value": "NON_US_BSLH", "params": []}],                                
  "GT":                  [{"value": "LS", "params": [{"value": "NON_US_BSLH", "params": []}]}],   # > -> Shift + <
  "LS(DOT)":             [{"value": "LS", "params": [{"value": "NON_US_BSLH", "params": []}]}],   

  # --- Slashes & Pipes ---
  "FSLH":                [{"value": "LS", "params": [{"value": "DOT", "params": []}]}],           # / -> Shift + : key (US DOT position)
  "BSLH":                [{"value": "RA", "params": [{"value": "N8", "params": []}]}],            # \ -> AltGr + 8
  "PIPE":                [{"value": "RA", "params": [{"value": "N6", "params": []}]}],            # | -> AltGr + 6
  "LS(BSLH)":            [{"value": "RA", "params": [{"value": "N6", "params": []}]}],   

  # --- Quotes & Ticks ---
  "SQT":                 [{"value": "N4", "params": []}],                                         # ' -> ' key (US N4)
  "SINGLE_QUOTE":        [{"value": "N4", "params": []}],                                  
  "DQT":                 [{"value": "N3", "params": []}],                                         # " -> " key (US N3)
  "LS(SINGLE_QUOTE)":    [{"value": "N3", "params": []}],            
  "LS(SQT)":             [{"value": "N3", "params": []}],            
  "GRAVE":               [{"value": "RA", "params": [{"value": "N7", "params": []}]}],            # ` -> AltGr + 7

  # --- Special Symbols ---
  "EXCLM":               [{"value": "FSLH", "params": []}],                                       # ! -> ! key (US FSLH position)
  "LS(N1)":              [{"value": "FSLH", "params": []}],            
  "AT":                  [{"value": "RA", "params": [{"value": "N0", "params": []}]}],            # @ -> AltGr + 0
  "LS(N2)":              [{"value": "RA", "params": [{"value": "N0", "params": []}]}],             
  "HASH":                [{"value": "RA", "params": [{"value": "N3", "params": []}]}],            # # -> AltGr + 3
  "LS(N3)":              [{"value": "RA", "params": [{"value": "N3", "params": []}]}],                                
  "DLLR":                [{"value": "RBKT", "params": []}],                                       # $ -> $ key (US RBKT position)
  "LS(N4)":              [{"value": "RBKT", "params": []}],            
  "PRCNT":               [{"value": "LS", "params": [{"value": "SQT", "params": []}]}],           # % -> Shift + ù key (US SQT position)
  "LS(N5)":              [{"value": "LS", "params": [{"value": "SQT", "params": []}]}],            
  "CARET":               [{"value": "LBKT", "params": []}],                                       # ^ -> ^ key (US LBKT dead key)
  "LS(N6)":              [{"value": "LBKT", "params": []}],                                      
  "AMPS":                [{"value": "N1", "params": []}],                                         # & -> & key (US N1)
  "LS(N7)":              [{"value": "N1", "params": []}],            
  "STAR":                [{"value": "BSLH", "params": []}],                                       # * -> * key (US BSLH position)
  "LS(N8)":              [{"value": "BSLH", "params": []}],          
  "TILDE":               [{"value": "RA", "params": [{"value": "N2", "params": []}]}],            # ~ -> AltGr + 2
  "LS(GRAVE)":           [{"value": "RA", "params": [{"value": "N2", "params": []}]}],          
  "UNDER":               [{"value": "N8", "params": []}],                                         # _ -> _ key (US N8)
  "UNDERSCORE":          [{"value": "N8", "params": []}],          
  "LS(MINUS)":           [{"value": "N8", "params": []}],          
  "QMARK":               [{"value": "LS", "params": [{"value": "M", "params": []}]}],             # ? -> Shift + , key (US M position)
  "LS(FSLH)":            [{"value": "LS", "params": [{"value": "M", "params": []}]}],         
  "COLON":               [{"value": "DOT", "params": []}],                                        # : -> : key (US DOT position)
  "LS(SEMI)":            [{"value": "DOT", "params": []}],           
  "SEMI":                [{"value": "COMMA", "params": []}]                                       # ; -> ; key (US COMMA position)
} as $french_symbol_map |

# ==============================================================================
# CONFIGURATION TARGETS
# ==============================================================================

.locale = "fr-FR-AZERTY" |
"Symbol" as $layer_to_translate |

# ==============================================================================
# BEHIND-THE-SCENES TRANSLATION ENGINE
# ==============================================================================

(.layer_names // .keymap.layer_names) as $all_layers |

if $all_layers == null then
  "Error: Could not find any keyboard layer names in this file." | halt_error
else
  ($all_layers | index($layer_to_translate)) as $layer_index |

  if $layer_index == null then
    "Error: The layer named '\($layer_to_translate)' does not exist." | halt_error
  else
    if .keymap.layers then .keymap.layers else .layers end |= (
      .[$layer_index] |= map(
        if . == null or .value != "&kp" or .params == null or .params == [] then 
          .
        else
          # Extracts inner parameters safely to eliminate the outer wrapper mismatch
          (.params[0] | if .params == null or .params == [] then .value else "\(.value)(\(.params[0].value))" end) as $current_key |
          
          if $french_symbol_map[$current_key] then 
            .params = $french_symbol_map[$current_key] 
          else 
            . 
          end
        end
      )
    )
  end
end


"""
[manifest]
author = "moosyresearch"
keyboards = ["go60","glove80"]
icon = "🇫🇷"      
# Optional: red, green, blue, purple, yellow, orange
theme = "blue" 
[config]
category = "Languages & Symbols"
num = 123
