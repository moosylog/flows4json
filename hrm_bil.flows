        "23": "none", "24": "none", "25": "none", "26": "none", "27": "none", "28": "none", "29": "HOME", "30": "UP", "31": "END", "32": "PG_UP",
        "35": "none", "36": "none", "37": "none", "38": "none", "39": "none", "40": "none", "41": "LEFT", "42": "DOWN", "43": "RIGHT", "44": "PG_DN",
        "47": "none", "48": "none", "49": "none", "50": "none", "51": "none", "64": "none", "65": "none", "66": "none", "67": "none", "68": "none",
        "53": "DEL"
      }
    },
    {
      "name": "Magic",
      "overrides": {
        "15": "none", "16": "none", "17": "none", "18": "none", "19": "none",
        "21": "none", "27": "&rgb_ug|RGB_SPI", "28": "&rgb_ug|RGB_SAI", "29": "&rgb_ug|RGB_HUI", "30": "&rgb_ug|RGB_BRI", "31": "&rgb_ug|RGB_TOG", "32": "none", "33": "none",
        "39": "none", "40": "none", "41": "&bootloader", "42": "&rgb_ug|RGB_SPD", "43": "&rgb_ug|RGB_SAD", "44": "&rgb_ug|RGB_HUD", "45": "&rgb_ug|RGB_BRD", "46": "&rgb_ug|RGB_EFF", "47": "none", "48": "none",
        "51": "none", "64": "none", "65": "&bootloader", "66": "&sys_reset", "67": "none", "68": "none", "69": "none",
        "52": "none", "53": "none", "54": "none", "55": "none", "56": "none", "57": "none",
        "70": "none", "71": "none", "72": "none", "73": "none", "74": "&sys_reset",
        "58": "&bt|BT_SEL|0", "59": "&bt|BT_SEL|1", "60": "&bt|BT_SEL|2", "61": "&bt|BT_SEL|3", "62": "&bt|BT_CLR"
      }
    }
  ] as $injection_layers |

  # ==========================================
  # 5. ATOMIC REGISTRATION ENGINE
  # ==========================================
  # Single-pass loop maps variables and inserts layers atomically to respect the Bilateral Sync Rule
  reduce $injection_layers[] as $l (.;
    (.layer_names | index($l.name)) as $idx |
    build_layer($l.overrides) as $computed_keys |
    if $idx != null then
      .layers[$idx] = $computed_keys
    else
      .layer_names += [$l.name] |
      .layers += [$computed_keys]
    end
  )
)
"""

# ==============================================================================
# UI PARAMETERS 
# ==============================================================================

[[param]]
id = "target_version"
label = "HRM flavor"
type = "select"
options = ["2", "3"]
labels = ["Urob timeless", "Sunaku per finger"]
default = "2"

[[param]]
id = "mod_preset"
label = "Recommended order"
type = "select"
options = ["GACS", "CAGS"]
labels = ["Windows / Linux", "macOS"]
default = "GACS"

[[param]]
id = "preserve_decorators"
label = "Preserve UI Decorators"
type = "boolean"
default = true

# ==============================================================================
# METADATA & CONFIG
# ==============================================================================

[manifest]
author = "moosyresearch"
keyboards = ["glove80"]
icon = "⚠️"      
# Optional: red, green, blue, purple, yellow, orange
theme = "green" 
[config]
category = "Home-Row Mods"
