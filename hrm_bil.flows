uid = "hrm_add"
type = "mutation"
language = "us"
title = "⚠️Bil Home-Row Mods"
subtitle = "in progress!!🛠️"
description = """
Home-row mods let your home-row keys do two things: act as normal letters when tapped, and as modifier keys when held. 

WORK IN PRGRESS
"""

# ==============================================================================
# JQ SCRIPT (Must remain at the top before any headers!)
# ==============================================================================
script = """
# ZMK Name-Aware Injection (V2.0 - Massively Optimized)
(if type == "object" and .keymap? then .keymap else . end) |= (

  # ==========================================
  # 1. CORE HARDWARE GEOMETRY & SPATIAL MATRICES
  # ==========================================
  [57,56,55,72,73,74,5,6,7,8,16,17,18,19,20,28,29,30,31,32,40,41,42,43,44,58,59,60,61,62,75,76,77,78,9,21,33,45,63,79,52,53,54,70,71,69] as $left_pos |
  [0,10,22,34,46,64,65,47,35,23,1,2,12,11,24,36,48,66,67,49,37,25,13,3,4,14,15,27,26,38,39,51,50,68,52,53,54,71,70,69,55,56,57,74,73,72] as $right_pos |
  [0,10,22,46,64,65,47,52,51,39,27,15,4,3,2,1,11,23,35,34,48,66,69,70,71,54,53,55,56,57,74,73,72,68,67,49,50,38,26,14,13,25,37,24,12,36] as $right_alt_pos |

  # ==========================================
  # 2. HELPER FUNCTIONS (THE NORMALIZATION ENGINE)
  # ==========================================
  # Parses compact shorthand layout syntax into valid MoErgo schema binding objects
  def parse_key:
    if type == "string" then
      if startswith("&") then { "value": . }
      else { "value": "&kp", "params": [{ "value": . }] }
      end
    elif type == "array" then
      { "value": .[0], "params": (.[1:] | map(if type == "string" or type == "number" then { "value": . } else parse_key end)) }
    else
      .
    end;

  # Builds a full 80-key hardware layer from a sparse index-override map
  def build_layer($overrides):
    [range(80)] | map(tostring as $idx | if $overrides[$idx] then $overrides[$idx] else "&trans" end | parse_key);

  # ==========================================
  # 3. ALGORITHMIC HOLD-TAP GENERATOR LOOP
  # ==========================================
  # Generates all 32 Home Row Modifier combinations dynamically using cross-product multiplication loops
  .holdTaps = [
    # Loop over hands
    ( [{hand: "left", pos: $left_pos}, {hand: "right", pos: $right_pos}][] ) as $h |
    # Loop over fingers
    ( [{f: "index", t: 180, i: 100}, {f: "middy", t: 210, i: 150}, {f: "ring", t: 240, i: 100}, {f: "pinky", t: 270, i: 150}][] ) as $f |
    
    # A. Generate Base Finger Behavior
    {
      "name": ("&HRM_" + $h.hand + "_" + $f.f + "_v1B_TKZ"),
      "description": ("HRM_" + $h.hand + "_" + $f.f + "_bilateral -> &HRM_" + $h.hand + "_" + $f.f + "_hold -> &kp - TailorKey"),
      "bindings": [ ("&HRM_" + $h.hand + "_" + $f.f + "_hold_v1B_TKZ"), "&kp" ],
      "tappingTermMs": $f.t, "flavor": "tap-preferred", "quickTapMs": 300, "requirePriorIdleMs": $f.i, "holdTriggerOnRelease": true,
      "holdTriggerKeyPositions": $h.pos
    },
    
    # B. Generate Cross-Finger Positional Intercept Behaviors
    (["index", "middy", "ring", "pinky"][] | select(. != $f.f)) as $other |
    {
      "name": (if $h.hand == "left" and $f.f == "index" and $other == "ring" then "&HRM_left_index_ringv1_TKZ" else "&HRM_" + $h.hand + "_" + $f.f + "_" + $other + "_v1B_TKZ" end),
      "description": ("HRM_" + $h.hand + "_" + $f.f + "_" + $other + "_bilateral -> &kp - &HRM_" + $h.hand + "_" + $f.f + "_tap - TailorKey"),
      "bindings": [ "&kp", ("&HRM_" + $h.hand + "_" + $f.f + "_tap_v1B_TKZ") ],
      "tappingTermMs": $f.t, "flavor": "tap-preferred", "quickTapMs": 300, "requirePriorIdleMs": $f.i, "holdTriggerOnRelease": true,
      "holdTriggerKeyPositions": (if $h.hand == "right" and $f.f == "middy" and $other == "pinky" then $right_alt_pos else $h.pos end)
    }
  ] |

  .macros = [] | # Injected safely if user macro definitions are needed

  # ==========================================
  # 4. SPARSE LAYER DICTIONARY (THE DATA CARRIER)
  # ==========================================
  # Only specify active keys. Unspecified indices automatically fallback to "&trans" to obey Matrix Consistency
  [
    {
      "name": "HRM_WinLinx",
      "overrides": {
        "0": "F1", "1": "F2", "2": "F3", "3": "F4", "4": "F5", "5": "F6", "6": "F7", "7": "F8", "8": "F9", "9": "F10",
        "10": "EQUAL", "11": "N1", "12": "N2", "13": "N3", "14": "N4", "15": "N5", "16": "N6", "17": "N7", "18": "N8", "19": "N9", "20": "N0", "21": "MINUS",
        "22": "TAB", "23": "Q", "24": "W", "25": "E", "26": "R", "27": "T", "28": "Y", "29": "U", "30": "I", "31": "O", "32": "P", "33": "BSLH",
        "34": "ESC", "35": "A", "36": "S", "37": "D", "38": "F", "39": "G", "40": "H", "41": "J", "42": "K", "43": "L", "44": "SEMI", "45": "SQT",
        "46": "GRAVE", "47": "Z", "48": "X", "49": "C", "50": "V", "51": "B", "64": "N", "65": "M", "66": "COMMA", "67": "DOT", "68": "FSLH", "69": "RCTRL",
        "52": ["&mo", 1], "53": "BSPC", "54": "LALT", "55": "LGUI", "56": "LSHFT", "57": ["&mo", 2],
