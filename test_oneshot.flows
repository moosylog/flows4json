uid = "sticky_oneshot_injector"
type = "mutation"
language = "us"
title = "OneShot Modifier"
subtitle = "OneShot Sticky Keys"
description = """
### **What is OneShot Shift?**

This tool adds a popular comfort feature to your keyboard, allowing you to type capital letters without straining your hands to hold down the Shift key. It turns Shift into a smart, two-in-one key:

*   **Tap the key:** It "sticks" on just long enough to capitalize your next letter, then turns off automatically.
*   **Hold the key:** It acts exactly like a normal Shift key until you let go.

---

### **What this script does:**

*   **Sets everything up automatically:** It safely adds all the hidden background settings needed to make this work (inspired by the popular Glorious Engrammer layout).
*   **Keeps your layout file safe:** It checks your file first before making changes. If you already have these settings installed, the script will safely stop and show a warning so it doesn't create duplicates.
*   **Gives you a working example:** It generates a new, safe test layer called `OneShot_example` with the new Shift key ready to go. You can simply copy this key over to your main typing layer!
"""

# ==============================================================================
# JQ SCRIPT
# ==============================================================================
script = """
(if type == "object" and .keymap? then .keymap else . end) |= (
  
  # 1. Pre-flight Conflict Checks
  (
    [
      (if (.stickyKeys // []) | any(.name == "&sticky_key_quickrel") then "- StickyKey: '&sticky_key_quickrel'" else empty end),
      (if (.macros // []) | any(.name == "&sticky_key_oneshot") then "- Macro: '&sticky_key_oneshot'" else empty end),
      (if (.holdTaps // []) | any(.name == "&sticky_key_modtap") then "- HoldTap: '&sticky_key_modtap'" else empty end),
      (if (.layer_names // []) | index("OneShot_example") != null then "- Layer: 'OneShot_example'" else empty end)
    ]
  ) as $conflicts |
  
  # Halt execution and print to stderr if conflicts exist
  if ($conflicts | length > 0) then
    error("ABORTED: The following items already exist in the layout:\n" + ($conflicts | join("\n")))
  else
    
    # 2. Determine Hardware Matrix Size dynamically
    (.layers[0] | length) as $kb_len |

    # 3. ── Sticky Keys (NEW Native Support) ──
    # No need for unique_by(.name) since we already verified they don't exist
    .stickyKeys = ((.stickyKeys // []) + [
      {
        "name": "&sticky_key_quickrel",
        "description": "",
        "releaseAfterMs": 500,
        "quickRelease": true,
        "lazy": false,
        "ignoreModifiers": true,
        "bindings": ["&kp"]
      }
    ]) |

    # 4. ── Macros ──
    .macros = ((.macros // []) + [
      {
        "name": "&sticky_key_oneshot",
        "description": "",
        "waitMs": 0,
        "tapMs": 0,
        "bindings": [
          {"value": "&macro_tap"},
          {"value": "&macro_param_1to1"},
          {
            "value": "&sticky_key_quickrel", 
            "params": [{"value": "MACRO_PLACEHOLDER"}]
          }
        ]
      }
    ]) |

    # 5. ── HoldTaps ──
    .holdTaps = ((.holdTaps // []) + [
      {
        "name": "&sticky_key_modtap",
        "description": "",
        "flavor": "tap-preferred",
        "tappingTermMs": 250,
        "bindings": ["&kp", "&sticky_key_oneshot"]
      }
    ]) |

    # 6. ── Layers ──
    .layer_names = ((.layer_names // []) + ["OneShot_example"]) |
    .layers = ((.layers // []) + [[
      range($kb_len) |
      
      # Inject the key at index 46. 
      if . == 46 then
        {
          "value": "&sticky_key_modtap",
          "params": [{"value": "LSHFT"}, {"value": "LSHFT"}],
          "decoration": {
            "label": "Shift",
            "icon": "fa-angle-double-up",
            "background": "#ffecb3"
          }
        }
      else
        {"value": "&none"}
      end
    ]])
  end
)
"""

[manifest]
author = "moosyresearch"
keyboards = ["glove80", "go60"]
icon = "✨"
theme = "purple"

[config]
category = "Test/Dev"
