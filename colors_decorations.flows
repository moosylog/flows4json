uid = "theme_colors"
type = "mutation"
language = "en-US"
title = "Smart Theme Colorizer"
subtitle = "Visual Themes, Macros & OS Swaps"
description = """
Automatically assigns key decorators based on key values, selected visual theme, and your operating system.

* **Home Row** styles apply exclusively to Layer 0.
* **Smart Shortcuts** (like Copy, Paste, Search, and Navigation) are automatically detected across *all* layers and assigned matching colors, labels, and icons.
* **OS Aware:** Automatically adjusts logical shortcuts for macOS (Command) vs. Windows (Control).
* Includes a **Clean Slate** mode to instantly remove all applied decorators from your layout.
"""

# ==============================================================================
# JQ SCRIPT
# ==============================================================================
script = """
# =========================================================
# 🛠️ USER CONFIGURATION ZONE 
# =========================================================

# --- 1. COLOR PALETTE CLASS ---
(if $theme == "engrammer" then {
  pinky: "#ffcdd2", ring: "#bbdefb", middy: "#dcedc8", index: "#ffecb3",
  clipboard: "#ffecb3", app: "#ffcdd2", system: "#dcedc8", nav: "#bbdefb", select: "#e0ebf6", browser: "#fbe6fe"
} elif $theme == "tailorkey" then {
  pinky: "#fbe6fe", ring: "#e5feff", middy: "#d9f9c9", index: "#fffec9",
  clipboard: "#fffec9", app: "#fbe6fe", system: "#f8e6d7", nav: "#d9f9c9", select: "#e0ebf6", browser: "#fbe6fe"
} elif $theme == "nordic" then {
  pinky: "#eceff4", ring: "#d8dee9", middy: "#b3d4e0", index: "#a3c9c6",
  clipboard: "#f0e2b6", app: "#e8b4b8", system: "#c4d7b2", nav: "#b3d4e0", select: "#a3c9c6", browser: "#d2c4d4"
} elif $theme == "sunset" then {
  pinky: "#ffc8a2", ring: "#ffb7b2", middy: "#e2f0cb", index: "#b5ead7",
  clipboard: "#fff2b2", app: "#ff9aa2", system: "#ffd3b6", nav: "#c7ceea", select: "#b5ead7", browser: "#e2b6cf"
} else {} end) as $pal |

# --- 2. DYNAMIC OS MODIFIER ---
(if $os == "mac" then "LG" else "LC" end) as $mod |

# --- 3. CATEGORIZED SEARCH MAP ---
# Use `os: "mac"` or `os: "win"` to restrict a shortcut. If omitted, it applies to both!
(
  [
    {
      bg: $pal.clipboard,
      items: {
        "&kp(__MOD__(C))": { icon: "fa-copy", label: "Copy" },
        "&kp(__MOD__(V))": { icon: "fa-paste", label: "Paste" },
        "&kp(__MOD__(X))": { icon: "fa-cut", label: "Cut" },
        "&kp(__MOD__(A))": { icon: "fa-object-group", label: "Select All" },
        "&kp(__MOD__(Z))": { icon: "fa-undo", label: "Undo" },
        "&kp(__MOD__(Y))": { icon: "fa-redo", label: "Redo", os: "win" },
        "&kp(LS(__MOD__(Z)))": { icon: "fa-redo", label: "Redo" },
        "&kp(__MOD__(LS(Z)))": { icon: "fa-redo", label: "Redo" }
      }
    },
    {
      bg: $pal.app,
      items: {
        "&kp(__MOD__(S))": { icon: "fa-save", label: "Save" },
        "&kp(__MOD__(N))": { icon: "fa-plus", label: "New" },
        "&kp(__MOD__(O))": { icon: "fa-folder-open", label: "Open" },
        "&kp(__MOD__(P))": { icon: "fa-print", label: "Print" },
        "&kp(__MOD__(W))": { icon: "fa-times", label: "Close" },
        "&kp(LG(Q))": { icon: "fa-power-off", label: "Quit App", os: "mac" },
        "&kp(LA(F4))": { icon: "fa-power-off", label: "Quit App", os: "win" },
        "&kp(LG(H))": { icon: "fa-eye-slash", label: "Hide App", os: "mac" },
        "&kp(LG(DOWN))": { icon: "fa-eye-slash", label: "Min App", os: "win" },
        "&kp(LG(E))": { icon: "fa-folder", label: "Explorer", os: "win" }
      }
    },
    {
      bg: $pal.system,
      items: {
        "&kp(__MOD__(F))": { icon: "fa-search", label: "Find" },
        "&kp(__MOD__(G))": { icon: "fa-search-plus", label: "Next" },
        "&kp(__MOD__(LS(G)))": { icon: "fa-search-minus", label: "Prev" },
        
        "&kp(LG(SPACE))": { icon: "fa-search", label: "Spotlight", os: "mac" },
        "&kp(LG(S))": { icon: "fa-search", label: "Search", os: "win" },
        "&kp(LG(D))": { icon: "fa-desktop", label: "Desktop", os: "win" },
        
        "&kp(LA(TAB))": { icon: "fa-exchange-alt", label: "Switch App", os: "win" },
        "&kp(LG(TAB))": { icon: "fa-tasks", label: "Switch / Tasks" },
        "&kp(LC(UP))": { icon: "fa-th-large", label: "Mission Ctrl", os: "mac" },
        
        "&kp(LG(GRAVE))": { icon: "fa-window-restore", label: "Next Win", os: "mac" },
        "&kp(LA(ESC))": { icon: "fa-window-restore", label: "Next Win", os: "win" },
        
        "&kp(LG(L))": { icon: "fa-lock", label: "Lock", os: "win" },
        "&kp(LC(LG(Q)))": { icon: "fa-lock", label: "Lock", os: "mac" },
        
        "&kp(PRINTSCREEN)": { icon: "fa-camera", label: "Screenshot", os: "win" },
        "&kp(LS(LG(S)))": { icon: "fa-crop", label: "Snip Tool", os: "win" },
        "&kp(LS(LG(N4)))": { icon: "fa-crop", label: "Screenshot", os: "mac" },
        
        "&kp(LG(DOT))": { icon: "fa-smile", label: "Emoji", os: "win" },
        "&kp(LC(LG(SPACE)))": { icon: "fa-smile", label: "Emoji", os: "mac" },

        "&kp(RET)": { description:  "Enter / Return" },
        "&kp(ESC)": { label:  "" }
      }
    },
    {
      bg: $pal.nav,
      items: {
        "&kp(HOME)": { label:  ""  },
        "&kp(END)": { label:  ""  },
        "&kp(UP)": { label:  ""  },
        "&kp(DOWN)": { label:  "" },
        "&kp(LEFT)": { label:  ""  },
        "&kp(RIGHT)": { label:  "" },
        "&kp(PG_UP)": { description: "Page Up" },
        "&kp(PG_DN)": { description: "Page Down" },

        "&kp(LG(LEFT))": { icon: "fa-step-backward", label: "Line Start", os: "mac" },
        "&kp(LG(RIGHT))": { icon: "fa-step-forward", label: "Line End", os: "mac" },
        
        "&kp(LC(HOME))": { icon: "fa-fast-backward", label: "Doc Top", os: "win" },
        "&kp(LG(UP))": { icon: "fa-fast-backward", label: "Doc Top", os: "mac" },
        "&kp(LC(END))": { icon: "fa-fast-forward", label: "Doc Bottom", os: "win" },
        "&kp(LG(DOWN))": { icon: "fa-fast-forward", label: "Doc Bottom", os: "mac" },
        
        "&kp(LC(LEFT))": { icon: "fa-angle-double-left", label: "Prev Word", os: "win" },
        "&kp(LA(LEFT))": { icon: "fa-angle-double-left", label: "Prev Word", os: "mac" },
        "&kp(LC(RIGHT))": { icon: "fa-angle-double-right", label: "Next Word", os: "win" },
        "&kp(LA(RIGHT))": { icon: "fa-angle-double-right", label: "Next Word", os: "mac" },

        "&kp(LC(BSPC))": { icon: "fa-backspace", label: "Del Word", os: "win" },
        "&kp(LA(BSPC))": { icon: "fa-backspace", label: "Del Word", os: "mac" },
        "&kp(LG(BSPC))": { icon: "fa-times-circle", label: "Del Line", os: "mac" }
      }
    },
    {
      bg: $pal.select,
      items: {
        "&kp(LS(HOME))": { icon: "fa-outdent", label: "Sel Start", os: "win" },
        "&kp(LS(LG(LEFT)))": { icon: "fa-outdent", label: "Sel Start", os: "mac" },
        "&kp(LS(END))": { icon: "fa-indent", label: "Sel End", os: "win" },
        "&kp(LS(LG(RIGHT)))": { icon: "fa-indent", label: "Sel End", os: "mac" },
        
        "&kp(LS(LC(HOME)))": { icon: "fa-level-up-alt", label: "Sel Top", os: "win" },
        "&kp(LS(LG(UP)))": { icon: "fa-level-up-alt", label: "Sel Top", os: "mac" },
        "&kp(LS(LC(END)))": { icon: "fa-level-down-alt", label: "Sel Bottom", os: "win" },
        "&kp(LS(LG(DOWN)))": { icon: "fa-level-down-alt", label: "Sel Bottom", os: "mac" },

        "&kp(LS(LC(LEFT)))": { icon: "fa-angle-left", label: "Sel Prev", os: "win" },
        "&kp(LS(LA(LEFT)))": { icon: "fa-angle-left", label: "Sel Prev", os: "mac" },
        "&kp(LS(LC(RIGHT)))": { icon: "fa-angle-right", label: "Sel Next", os: "win" },
        "&kp(LS(LA(RIGHT)))": { icon: "fa-angle-right", label: "Sel Next", os: "mac" }
      }
    },
    {
      bg: $pal.browser,
      items: {
        "&kp(__MOD__(L))": { icon: "fa-link", label: "Focus URL" },
        "&kp(__MOD__(T))": { icon: "fa-plus-square", label: "New Tab" },
        "&kp(LS(__MOD__(T)))": { icon: "fa-history", label: "Reopen Tab" },
        "&kp(LC(TAB))": { icon: "fa-chevron-right", label: "Next Tab" },
        "&kp(LS(LC(TAB)))": { icon: "fa-chevron-left", label: "Prev Tab" },
        "&kp(__MOD__(R))": { icon: "fa-sync", label: "Refresh" },
        "&kp(LS(__MOD__(R)))": { icon: "fa-sync-alt", label: "Hard Refresh" },
        "&kp(LC(F5))": { icon: "fa-sync-alt", label: "Hard Refresh", os: "win" }
      }
    }
  ] 
  | map(.bg as $bg | .items | with_entries(
      select(.value.os == null or .value.os == "both" or .value.os == $os) |
      .key |= gsub("__MOD__"; $mod) | 
      .value.background = $bg |
      .value |= del(.os)
    )) 
  | add
) as $logical_map |


# =========================================================
# ⚙️ INTERNAL ENGINE 
# =========================================================

(.keyboard? | if type == "string" then ascii_downcase else "glove80" end) as $kb |

# --- HARDWARE INDEX MAP ---
(if $kb == "glove80" then {
  "35": "left.pinky", "36": "left.ring", "37": "left.middy", "38": "left.index",
  "41": "right.index", "42": "right.middy", "43": "right.ring", "44": "right.pinky"
} elif $kb == "go60" then {
  "25": "left.pinky", "26": "left.ring", "27": "left.middy", "28": "left.index",
  "31": "right.index", "32": "right.middy", "33": "right.ring", "34": "right.pinky"
} else {} end) as $hw_map |

# --- HOME ROW THEME ASSIGNMENTS (WITH OS SWAP) ---
(if $os == "mac" then
  {
    left:  { pinky: {background: $pal.middy, icon: "fa-align-left"}, ring: {background: $pal.ring, icon: "fa-align-left"}, middy: {background: $pal.pinky, icon: "fa-align-left"}, index: {background: $pal.index, icon: "fa-align-left"} },
    right: { pinky: {background: $pal.middy, icon: "fa-align-right"}, ring: {background: $pal.ring, icon: "fa-align-right"}, middy: {background: $pal.pinky, icon: "fa-align-right"}, index: {background: $pal.index, icon: "fa-align-right"} }
  }
else
  {
    left:  { pinky: {background: $pal.pinky, icon: "fa-align-left"}, ring: {background: $pal.ring, icon: "fa-align-left"}, middy: {background: $pal.middy, icon: "fa-align-left"}, index: {background: $pal.index, icon: "fa-align-left"} },
    right: { pinky: {background: $pal.pinky, icon: "fa-align-right"}, ring: {background: $pal.ring, icon: "fa-align-right"}, middy: {background: $pal.middy, icon: "fa-align-right"}, index: {background: $pal.index, icon: "fa-align-right"} }
  }
end) as $homerow_theme |

# --- MUTATION ENGINE ---
(.keymap // .) |= (
  
  # --- DEEP SEARCH FLATTENER (Completely Type-Safe & Null-Proof) ---
  def GetSignature:
    if type == "object" and .value != null then
      (.params // []) as $p |
      if ($p | length > 0) then
        (.value | tostring) + "(" + ($p | map(GetSignature) | join(",")) + ")"
      else
        (.value | tostring)
      end
    else
      (. | tostring)
    end;

  if $mode == "delete" then
    # OVERRIDE: Strip ALL decorators from EVERY key on ALL layers
    if .layers then
      .layers |= map(map(if type == "object" then del(.decoration) else . end))
    else . end
  else
    # --- APPLY STYLES ---
    if .layers then
      .layers |= [
        range(length) as $layerIdx | .[$layerIdx] |
        [
          range(length) as $keyIdx | .[$keyIdx] |
          
          # A. Resolve Physical Home Row Style (Layer 0 ONLY)
          (if $layerIdx == 0 then $hw_map[$keyIdx | tostring] else null end) as $finger_path |
          (if $finger_path then ($homerow_theme | getpath($finger_path | split("."))) else null end) as $physical_style |
          
          # B. Resolve Logical Search Style (ALL Layers)
          (GetSignature) as $sig |
          ($logical_map[$sig]) as $logical_style |
          
          # C. Priority logic (Logical Macros override Home Row colors)
          (if $logical_style then $logical_style
           elif $physical_style then $physical_style
           else null end) as $target_style |
          
          if $target_style then
            
            # Smart Label Extraction: Only if icon exists AND label is null/blank
            (
              if ($target_style.icon != null and ($target_style.label == null or $target_style.label == "")) and type == "object" then
                (.params // []) as $p |
                if ($p | length > 1) then
                  (if ($p[1] | type == "object") then ($p[1].value // $p[1]) else $p[1] end | tostring)
                elif ($p | length > 0) then
                  (if ($p[0] | type == "object") then ($p[0].value // $p[0]) else $p[0] end | tostring)
                else
                  $target_style.label
                end
              else
                $target_style.label
              end
            ) as $final_label |

            # Compile the decoration payload, explicitly stripping missing properties
            # ONLY strips nulls now. Allows "" (empty string) through to blank out labels!
            (
              {
                background: $target_style.background,
                color: $target_style.color,
                icon: $target_style.icon,
                description: $target_style.description,
                label: $final_label
              } | with_entries(select(.value != null))
            ) as $new_dec |
            
            # Apply the dynamic payload securely
            if type == "object" then
              .decoration = ((.decoration // {}) + $new_dec)
            else
              { "value": ., "params": [], "decoration": $new_dec }
            end
          else
            .
          end
        ]
      ]
    else . end
  end
)
"""

# ==============================================================================
# UI PARAMETERS 
# ==============================================================================

[[param]]
id = "mode"
label = "Execution Mode"
type = "select"
options = ["apply", "delete"]
labels = ["🎨 Apply Theme Colors", "🗑️ DELETE APPLIED Decorators"]
default = "apply"

[[param]]
id = "os"
label = "Operating System"
type = "select"
options = ["win", "mac"]
labels = ["Windows / Linux", "macOS (Swaps Pinky & Middle)"]
default = "win"

[[param]]
id = "theme"
label = "Color Theme"
type = "select"
options = ["engrammer", "tailorkey", "nordic", "sunset"]
labels = ["Glorious Engrammer", "TailorKey", "Nordic Frost", "Sunset Horizon"]
default = "tailorkey"

# ==============================================================================
# METADATA & CONFIG
# ==============================================================================

[manifest]
author = "moosyresearch"
keyboards = ["go60", "glove80"]
icon = "🌈"
theme = "purple"

[config]
category = "Decorations & RGB"
