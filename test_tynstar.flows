uid = "tynstar_bindings"
type = "mutation"
language = "us"
title = "Tynstar Combo & Base Bindings"
subtitle = "Wires up custom Tynstar ZMK behaviors"
description = """
Automatically assigns spatial combos and base-layer modifications to your custom Tynstar ZMK definitions.

⚠️ **Prerequisite:** Ensure you have pasted your raw ZMK `behaviors {}` and `macros {}` blocks into the MoErgo Custom Behaviors and Custom Macros UI before compiling!
"""

script = """
(.keymap.layers[0] // .layers[0]) as $base_layer |
($base_layer | length) as $len |

(if .keymap then .keymap else . end) |= (
  
  # ------------------------------------------------------------------------------
  # 1. INFINIKEY LAYER INITIALIZATION
  # ------------------------------------------------------------------------------
  (
    .layer_names |= (. // []) | .layers |= (. // []) |
    if (.layer_names | index("InfiniKey") == null) then 
      .layer_names += ["InfiniKey"] | 
      .layers += [[
        range($len) as $i | 
        {"value": "&kp", "params": [{"value": ("F" + (($i % 24 + 1) | tostring))}]}
      ]] 
    else . end
  ) |
  
  (.layer_names | index("InfiniKey")) as $idx_infini |

  # ------------------------------------------------------------------------------
  # 2. BASE LAYER REPLACEMENTS (Shift, Esc, PRTSC, RALT, Magic)
  # ------------------------------------------------------------------------------
  .layers[0] = [
    range($len) as $i |
    $base_layer[$i] as $k |
    (if ($k | type == "object") then ($k.params[0].value // "") else ($k | tostring) end) as $val |

    if $val == "LSHFT" then
      {"value": "&parsl", "params": []}
    elif $val == "RSHFT" then
      {"value": "&parsr", "params": []}
    elif $val == "ESC" then
      {"value": "&strong", "params": [{"value": "ESC"}, {"value": "0"}]}
    elif $val == "PSCRN" or $val == "PRINTSCREEN" then
      {"value": "&strong", "params": [{"value": "PSCRN"}, {"value": "0"}]}
    elif $val == "RALT" then
      {"value": "&kp", "params": [{"value": "LALT"}]}
    elif (if ($k | type == "object") then $k.value == "&magic" else ($k | type == "string" and startswith("&magic")) end) then
      {"value": "&sl", "params": [{"value": ($idx_infini | tostring)}]}
    else
      $k
    end
  ] |

  # ------------------------------------------------------------------------------
  # 3. COMBO GENERATOR (Pointing to your custom Mod-Morphs & Macros)
  # ------------------------------------------------------------------------------
  (
    [
      .layers[0][] | 
      if type == "object" and (.value == "&kp" or .value == "&parsl" or .value == "&parsr" or .value == "&strong") then (.params[0].value // "")
      elif type == "string" and startswith("&kp ") then (split(" ")[1] // "")
      else "" end
    ]
  ) as $l0_kps |
  
  (
    [
      # -- HORIZONTAL COMBOS --
      {"n": "Combo_Home", "k1": ["H"], "k2": ["J"], "b": "&kp", "p": ["HOME"]},
      {"n": "Combo_End", "k1": ["K"], "k2": ["L"], "b": "&kp", "p": ["END"]},
      {"n": "Combo_Cut", "k1": ["X"], "k2": ["C"], "b": "&kp", "p": ["LC(X)"]},
      {"n": "Combo_Copy", "k1": ["C"], "k2": ["V"], "b": "&kp", "p": ["LC(C)"]},
      {"n": "Combo_Paste", "k1": ["V"], "k2": ["B"], "b": "&kp", "p": ["LC(V)"]},
      {"n": "Combo_SelAll", "k1": ["A"], "k2": ["S"], "b": "&kp", "p": ["LC(A)"]},
      {"n": "Combo_Undo", "k1": ["Z"], "k2": ["X"], "b": "&kp", "p": ["LC(Z)"]},
      {"n": "Combo_Enter", "k1": ["BSPC", "BACKSPACE"], "k2": ["DEL", "DELETE"], "b": "&kp", "p": ["RET"]},
      {"n": "Combo_Space", "k1": ["DEL", "DELETE"], "k2": ["LGUI", "RGUI", "WIN", "COMMAND"], "b": "&kp", "p": ["SPACE"]},
      {"n": "Combo_Home_Arr", "k1": ["BSLH"], "k2": ["LEFT"], "b": "&kp", "p": ["HOME"]},
      {"n": "Combo_End_Arr", "k1": ["LEFT"], "k2": ["RIGHT"], "b": "&kp", "p": ["END"]},
      {"n": "Combo_PgUp", "k1": ["UP"], "k2": ["DOWN"], "b": "&kp", "p": ["PG_UP"]},
      {"n": "Combo_PgDn", "k1": ["DOWN"], "k2": ["LBKT"], "b": "&kp", "p": ["PG_DN"]},

      # -- VERTICAL COMBOS (Mapped to your custom ZMK Mod-Morphs/Macros) --
      {"n": "Combo_AE", "k1": ["A"], "k2": ["Z"], "b": "&xauml", "p": []},
      {"n": "Combo_UE", "k1": ["U"], "k2": ["J"], "b": "&xuuml", "p": []},
      {"n": "Combo_OE", "k1": ["O"], "k2": ["L"], "b": "&xouml", "p": []},
      {"n": "Combo_SS", "k1": ["S"], "k2": ["X"], "b": "&xszlig", "p": []},
      {"n": "Combo_EUR", "k1": ["E"], "k2": ["D"], "b": "&xeuro", "p": []},
      {"n": "Combo_DEG", "k1": ["D"], "k2": ["C"], "b": "&xdegree", "p": []},
      {"n": "Combo_MUL", "k1": ["X"], "k2": ["BSLH"], "b": "&xmultiply", "p": []},
      {"n": "Combo_ELP", "k1": ["DOT"], "k2": ["LBKT"], "b": "&xellipsis", "p": []}
    ] | map(
      . as $c |
      ($l0_kps | to_entries | map(select(.value as $v | $c.k1 | index($v))) | if length > 0 then .[0].key else null end) as $i1 |
      ($l0_kps | to_entries | map(select(.value as $v | $c.k2 | index($v))) | if length > 0 then .[0].key else null end) as $i2 |
      if $i1 != null and $i2 != null then
        {
          "name": $c.n,
          "keyPositions": [$i1, $i2],
          "bindings": [{"value": $c.b, "params": ($c.p | map({"value": .}))}],
          "layers": [0],
          "timeoutMs": 50
        }
      else empty end
    )
  ) as $new_combos |

  .combos = ((.combos // []) + $new_combos | unique_by(.name // .keyPositions))
)
"""

[manifest]
author = "tynstar"
keyboards = ["glove80", "go60"]
icon = "✨"
theme = "Test/Dev"

[config]
category = "Custom Behaviors"
