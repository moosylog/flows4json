uid = "de_symbol"
type = "mutation"
language = "us"
title = "🌍 Symbols to German"
subtitle = "Map from en-US to de-DE"
description = """
When you change the language settings in the MoErgo Layout Editor from the default US English keyboard layout (en-US) to German (de-DE), some symbols no longer match their expected characters.

This flow remaps those symbols so they produce the correct characters for the German layout.

⚠️ REQUIRED: a layout with a 'Symbol Layer'
🪳 QUALITY: AI-generated content — not fully tested and may contain bugs.
"""
script = """
# ==============================================================================
#             GERMAN SYMBOL MAPPER (For MoErgo Layout Editor / ZMK)
#             OS TARGET: WINDOWS / LINUX (Standard ISO / de-DE)
# ==============================================================================

{
  # --- Punctuation & Basics ---
  "DOT":                 [{"value": "DOT", "params": []}],                                        # . -> .
  "COMMA":               [{"value": "COMMA", "params": []}],                                      # , -> ,
  "EQUAL":               [{"value": "LS", "params": [{"value": "N0", "params": []}]}],            # = -> Shift + 0

  # --- Fixed Column 4 Realignment ---
  "MINUS":               [{"value": "LS", "params": [{"value": "FSLH", "params": []}]}],          # Source Minus -> German Underscore (Shift + -)
  "UNDER":               [{"value": "FSLH", "params": []}],                                       # Source Underscore -> German Minus (- key)
  "UNDERSCORE":          [{"value": "FSLH", "params": []}],                                       
  "LS(MINUS)":           [{"value": "FSLH", "params": []}],                                       
  "PLUS":                [{"value": "RBKT", "params": []}],                                       # + -> + key (German physical RBKT)

  # --- Brackets & Braces ---
  "LPAR":                [{"value": "LS", "params": [{"value": "N8", "params": []}]}],            # ( -> Shift + 8
  "LS(N9)":              [{"value": "LS", "params": [{"value": "N8", "params": []}]}],            
  "RPAR":                [{"value": "LS", "params": [{"value": "N9", "params": []}]}],            # ) -> Shift + 9
  "LS(N0)":              [{"value": "LS", "params": [{"value": "N9", "params": []}]}],            
  "LBKT":                [{"value": "RA", "params": [{"value": "N8", "params": []}]}],            # [ -> AltGr + 8
  "RBKT":                [{"value": "RA", "params": [{"value": "N9", "params": []}]}],            # ] -> AltGr + 9
  "LBRC":                [{"value": "RA", "params": [{"value": "N7", "params": []}]}],            # { -> AltGr + 7
  "LS(LBKT)":            [{"value": "RA", "params": [{"value": "N7", "params": []}]}],            
  "RBRC":                [{"value": "RA", "params": [{"value": "N0", "params": []}]}],            # } -> AltGr + 0
  "LS(RBKT)":            [{"value": "RA", "params": [{"value": "N0", "params": []}]}],            
  "LT":                  [{"value": "NON_US_BSLH", "params": []}],                                # < -> < key
  "LS(COMMA)":           [{"value": "NON_US_BSLH", "params": []}],                                
  "GT":                  [{"value": "LS", "params": [{"value": "NON_US_BSLH", "params": []}]}],   # > -> Shift + <
  "LS(DOT)":             [{"value": "LS", "params": [{"value": "NON_US_BSLH", "params": []}]}],   

  # --- Slashes & Pipes ---
  "FSLH":                [{"value": "LS", "params": [{"value": "N7", "params": []}]}],            # / -> Shift + 7
  "BSLH":                [{"value": "RA", "params": [{"value": "MINUS", "params": []}]}],         # \ -> AltGr + ß
  "PIPE":                [{"value": "RA", "params": [{"value": "NON_US_BSLH", "params": []}]}],   # | -> AltGr + <
  "LS(BSLH)":            [{"value": "RA", "params": [{"value": "NON_US_BSLH", "params": []}]}],   

  # --- Quotes & Ticks ---
  "SQT":                 [{"value": "LS", "params": [{"value": "NON_US_HASH", "params": []}]}],   # ' -> Shift + #
  "SINGLE_QUOTE":        [{"value": "LS", "params": [{"value": "NON_US_HASH", "params": []}]}],   
  "DQT":                 [{"value": "LS", "params": [{"value": "N2", "params": []}]}],            # " -> Shift + 2
  "LS(SINGLE_QUOTE)":    [{"value": "LS", "params": [{"value": "N2", "params": []}]}],            
  "LS(SQT)":             [{"value": "LS", "params": [{"value": "N2", "params": []}]}],            
  "GRAVE":               [{"value": "LS", "params": [{"value": "EQUAL", "params": []}]}],         # ` -> Shift + ´

  # --- Special Symbols (Number Row & Misc) ---
  "EXCLM":               [{"value": "LS", "params": [{"value": "N1", "params": []}]}],            # ! -> Shift + 1
  "LS(N1)":              [{"value": "LS", "params": [{"value": "N1", "params": []}]}],            
  "AT":                  [{"value": "RA", "params": [{"value": "Q", "params": []}]}],             # @ -> AltGr + Q
  "LS(N2)":              [{"value": "RA", "params": [{"value": "Q", "params": []}]}],             
  "HASH":                [{"value": "NON_US_HASH", "params": []}],                                # # -> # key
  "LS(N3)":              [{"value": "NON_US_HASH", "params": []}],                                
  "DLLR":                [{"value": "LS", "params": [{"value": "N4", "params": []}]}],            # $ -> Shift + 4
  "LS(N4)":              [{"value": "LS", "params": [{"value": "N4", "params": []}]}],            
  "PRCNT":               [{"value": "LS", "params": [{"value": "N5", "params": []}]}],            # % -> Shift + 5
  "LS(N5)":              [{"value": "LS", "params": [{"value": "N5", "params": []}]}],            
  "CARET":               [{"value": "GRAVE", "params": []}],                                      # ^ -> ^ key (top left)
  "LS(N6)":              [{"value": "GRAVE", "params": []}],                                      
  "AMPS":                [{"value": "LS", "params": [{"value": "N6", "params": []}]}],            # & -> Shift + 6
  "LS(N7)":              [{"value": "LS", "params": [{"value": "N6", "params": []}]}],            
  "STAR":                [{"value": "LS", "params": [{"value": "RBKT", "params": []}]}],          # * -> Shift + +
  "LS(N8)":              [{"value": "LS", "params": [{"value": "RBKT", "params": []}]}],          
  "TILDE":               [{"value": "RA", "params": [{"value": "RBKT", "params": []}]}],          # ~ -> AltGr + +
  "LS(GRAVE)":           [{"value": "RA", "params": [{"value": "RBKT", "params": []}]}],          
  "QMARK":               [{"value": "LS", "params": [{"value": "MINUS", "params": []}]}],         # ? -> Shift + ß
  "LS(FSLH)":            [{"value": "LS", "params": [{"value": "MINUS", "params": []}]}],         
  "COLON":               [{"value": "LS", "params": [{"value": "DOT", "params": []}]}],           # : -> Shift + .
  "LS(SEMI)":            [{"value": "LS", "params": [{"value": "DOT", "params": []}]}],           
  "SEMI":                [{"value": "LS", "params": [{"value": "COMMA", "params": []}]}]          # ; -> Shift + ,
} as $german_symbol_map |

# ==============================================================================
# CONFIGURATION TARGETS
# ==============================================================================

.locale = "de-DE" |
"Symbol" as $layer_to_translate |

# ==============================================================================
# BEHIND-THE-SCENES TRANSLATION ENGINE
# ==============================================================================

(.layer_names // .keymap.layer_names) as $all_layers |

if $all_layers == null then
  "Error: Could not find any keyboard layer names in this file." | halt_error
else
  ($all_layers | index($layer_to_translate)) as $layer_index |

  if $layer_index == null then
    "Error: The layer named '\($layer_to_translate)' does not exist." | halt_error
  else
    # Outer logic block structures modifications correctly for standard JQ environments
    if .keymap.layers then
      .keymap.layers[$layer_index] |= map(
        if . == null or .value != "&kp" or .params == null or .params == [] then 
          .
        else
          (.params[0] | if .params == null or .params == [] then .value else "\(.value)(\(.params[0].value))" end) as $current_key |
          if $german_symbol_map[$current_key] then .params = $german_symbol_map[$current_key] else . end
        end
      )
    else
      .layers[$layer_index] |= map(
        if . == null or .value != "&kp" or .params == null or .params == [] then 
          .
        else
          (.params[0] | if .params == null or .params == [] then .value else "\(.value)(\(.params[0].value))" end) as $current_key |
          if $german_symbol_map[$current_key] then .params = $german_symbol_map[$current_key] else . end
        end
      )
    end
  end
end
"""
[manifest]
author = "moosyresearch"
keyboards = ["go60","glove80"]
icon = "🇩🇪"         # Optional: use any emoji or unicode
theme = "blue"       # Optional: red, green, blue, purple, yellow, orange
[config]
category = "Languages & Symbols"
num = 123
